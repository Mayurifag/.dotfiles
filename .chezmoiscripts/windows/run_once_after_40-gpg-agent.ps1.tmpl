{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = 'Stop'

Write-Host '[chezmoi] running windows/40-gpg-agent'

$gpgconf = "C:\Program Files\GnuPG\bin\gpgconf.exe"

if (-not (Test-Path $gpgconf)) {
    Write-Host "[gpg] WARNING: gpgconf.exe not found at expected path: $gpgconf" -ForegroundColor Yellow
    Write-Host "     Skipping scheduled task - install GnuPG and re-run 'chezmoi apply'." -ForegroundColor Yellow
    exit 0
}

$oldTaskName = "GpgAgentCleanupAtLogon"
$taskName = "GpgAgentRefreshAtLogon"
$killAction = New-ScheduledTaskAction -Execute $gpgconf -Argument "--kill gpg-agent"
$launchAction = New-ScheduledTaskAction -Execute $gpgconf -Argument "--launch gpg-agent"
$trigger = New-ScheduledTaskTrigger -AtLogOn -User $env:USERNAME
$settings = New-ScheduledTaskSettingsSet -ExecutionTimeLimit (New-TimeSpan -Minutes 1) -StartWhenAvailable

if (Get-ScheduledTask -TaskName $oldTaskName -ErrorAction SilentlyContinue) {
    Unregister-ScheduledTask -TaskName $oldTaskName -Confirm:$false
}

Register-ScheduledTask `
    -TaskName $taskName `
    -Action @($killAction, $launchAction) `
    -Trigger $trigger `
    -Settings $settings `
    -RunLevel Limited `
    -Force | Out-Null

Start-Process -FilePath $gpgconf -ArgumentList '--launch', 'gpg-agent' -WindowStyle Hidden

Write-Host "[gpg] Done. Scheduled task '$taskName' registered." -ForegroundColor Green
Write-Host "     gpgconf will refresh gpg-agent at every logon for $env:USERNAME."
{{- end }}
