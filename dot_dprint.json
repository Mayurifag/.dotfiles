{
  "plugins": [
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.21.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm"
  ],
  "json": {
    "indentWidth": 2,
    "useTabs": false
  },
  "markdown": {
    "textWrap": "always",
    "lineWidth": 120
  },
  "toml": {
    "indentWidth": 2,
    "useTabs": false
  },
  "includes": ["**/*.{json,jsonc,md,toml,yaml,yml}"],
  "excludes": ["**/node_modules", "**/.git", "**/.chezmoi*"]
}
