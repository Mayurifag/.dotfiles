# === Environment Variables ===
{{ template "env_vars_ps1" . }}
# === PATH Additions ===
$env:PATH = "$env:USERPROFILE\.cargo\bin;" + $env:PATH
$env:PATH = "$env:USERPROFILE\.local\bin;" + $env:PATH

# === Default directory ===
# On a fresh tab WT starts in System32; navigate to Code instead
if ((Get-Location).Path -eq "$env:SystemRoot\System32") { Set-Location ~\Code }

# === Shell Integration (Windows Terminal CWD tracking for same-dir new tabs) ===
# Starship overrides this prompt function automatically when active
function prompt {
    $loc = $executionContext.SessionState.Path.CurrentLocation
    $out = "PS $loc$('>' * ($nestedPromptLevel + 1)) "
    $out += "$([char]27)]9;12$([char]7)"
    if ($loc.Provider.Name -eq "FileSystem") {
        $out += "$([char]27)]9;9;`"$($loc.ProviderPath)`"$([char]7)"
    }
    return $out
}

# === Tool Activation (cached for speed) ===
$_cacheDir = "$env:LOCALAPPDATA\shell-cache"
if (-not (Test-Path $_cacheDir)) { New-Item -ItemType Directory -Path $_cacheDir -Force | Out-Null }

function _CachedInit([string]$name, [string]$exe, [scriptblock]$generator) {
    $cache = "$_cacheDir\$name.ps1"
    $exePath = (Get-Command $exe -ErrorAction SilentlyContinue)?.Source
    if ($exePath -and (Test-Path $cache) -and (Get-Item $cache).LastWriteTime -ge (Get-Item $exePath).LastWriteTime) {
        . $cache
    } else {
        $content = & $generator
        $content | Set-Content -Path $cache -Force
        . $cache
    }
}

# mise — version manager
_CachedInit 'mise' 'mise' { & mise activate pwsh }

# starship — cross-shell prompt
_CachedInit 'starship' 'starship' { starship init powershell }

Remove-Item -Path Function:\_CachedInit -ErrorAction SilentlyContinue
Remove-Variable _cacheDir

