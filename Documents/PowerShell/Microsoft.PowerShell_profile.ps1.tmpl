# === PATH Additions ===
function _PrependToPath([string]$dir) {
    if ([string]::IsNullOrWhiteSpace($dir) -or -not (Test-Path $dir)) { return }
    if (($env:PATH -split ';') -contains $dir) { return }
    $env:PATH = "$dir;$env:PATH"
}

# Cold start: skip dedup work. Re-source (czapply): dedup to avoid stacking.
if ($env:_PROFILE_LOADED) {
    _PrependToPath "$env:USERPROFILE\.cargo\bin"
    _PrependToPath "$env:USERPROFILE\.local\espanso_managed_bins"
    _PrependToPath "$env:USERPROFILE\.local\bin"
} else {
    $env:PATH = "$env:USERPROFILE\.local\bin;$env:USERPROFILE\.local\espanso_managed_bins;$env:USERPROFILE\.cargo\bin;$env:PATH"
}
$env:_PROFILE_LOADED = '1'

$script:_isInteractiveShell = try {
    [Environment]::UserInteractive -and -not [Console]::IsInputRedirected
} catch { $true }
$script:_hasZoxide = $null -ne (Get-Command zoxide -ErrorAction SilentlyContinue)

if ($script:_isInteractiveShell) {
    # Mirror zsh editor-style selection using PSReadLine's native widgets.
    Set-PSReadLineKeyHandler -Chord Ctrl+a -Function SelectAll
    Set-PSReadLineKeyHandler -Chord Shift+LeftArrow -Function SelectBackwardChar
    Set-PSReadLineKeyHandler -Chord Shift+RightArrow -Function SelectForwardChar
    Set-PSReadLineKeyHandler -Chord Ctrl+Shift+LeftArrow -Function SelectBackwardWord
    Set-PSReadLineKeyHandler -Chord Ctrl+Shift+RightArrow -Function SelectNextWord
    Set-PSReadLineKeyHandler -Chord Shift+Home -Function SelectBackwardsLine
    Set-PSReadLineKeyHandler -Chord Shift+End -Function SelectLine
    Set-PSReadLineKeyHandler -Chord Ctrl+Backspace -Function BackwardKillWord
    Set-PSReadLineKeyHandler -Chord Ctrl+Delete -Function KillWord
    Set-PSReadLineKeyHandler -Chord Ctrl+c -Function CopyOrCancelLine
    Set-PSReadLineKeyHandler -Chord Ctrl+Shift+c -Function Copy
    Set-PSReadLineKeyHandler -Chord Ctrl+x -Function Cut
    Set-PSReadLineKeyHandler -Chord Ctrl+v -Function Paste
    Set-PSReadLineKeyHandler -Chord Ctrl+z -Function Undo
    Set-PSReadLineKeyHandler -Chord Ctrl+Shift+z -Function Redo
}

# === Default directory ===
# On a fresh tab WT starts in System32; navigate to Code instead
if ((Get-Location).Path -eq "$env:SystemRoot\System32") { Set-Location ~\Code }

# === Tool Activation (cached for speed) ===
$_cacheDir = "$env:LOCALAPPDATA\shell-cache"
if (-not (Test-Path $_cacheDir)) { New-Item -ItemType Directory -Path $_cacheDir -Force | Out-Null }

if ($script:_isInteractiveShell) {
    function _CachedInit([string]$name, [string]$exe, [scriptblock]$generator) {
        $cache = "$_cacheDir\$name.ps1"
        $exePath = (Get-Command $exe -ErrorAction SilentlyContinue)?.Source
        if (-not $exePath) { return }

        $useCache = (Test-Path $cache) -and [IO.File]::GetLastWriteTime($cache) -ge [IO.File]::GetLastWriteTime($exePath)
        if (-not $useCache) {
            $content = & $generator 2>$null
            if (-not [string]::IsNullOrWhiteSpace($content)) {
                $content | Set-Content -Path $cache -Force
                $useCache = $true
            }
        }

        if ($useCache) {
            try {
                . $cache
            } catch {
                Remove-Item -Path $cache -Force -ErrorAction SilentlyContinue
            }
        }
    }

    # mise — version manager
    _CachedInit 'mise' 'mise' { & mise activate pwsh }

    # starship — cross-shell prompt
    _CachedInit 'starship' 'starship' { starship init powershell --print-full-init }

    # zoxide — smart cd
    _CachedInit 'zoxide' 'zoxide' { zoxide init powershell }

    Remove-Item -Path Function:\_CachedInit -ErrorAction SilentlyContinue
}

Remove-Item -Path Function:\_PrependToPath -ErrorAction SilentlyContinue

# === OSC 9;9 — report CWD to terminal (enables new-tab-in-same-dir) ===
if ($script:_isInteractiveShell) {
    $script:_terminalTitleGit = (Get-Command git -ErrorAction SilentlyContinue)?.Source
    $script:_terminalTitleLastPath = $null
    $script:_terminalTitleLastTitle = $null
    $script:_terminalTitleRepoNames = @{}

    function global:Invoke-Starship-PreCommand {
        $loc = $executionContext.SessionState.Path.CurrentLocation
        if ($loc.Provider.Name -eq 'FileSystem') {
            $path = $loc.ProviderPath
            if ($path -eq $script:_terminalTitleLastPath) {
                $title = $script:_terminalTitleLastTitle
            } else {
                $title = $path
                if ($script:_terminalTitleGit) {
                    $gitRoot = & $script:_terminalTitleGit -C $path rev-parse --show-toplevel 2>$null
                    if ($LASTEXITCODE -eq 0 -and $gitRoot) {
                        if ($script:_terminalTitleRepoNames.ContainsKey($gitRoot)) {
                            $repoName = $script:_terminalTitleRepoNames[$gitRoot]
                        } else {
                            $remoteOutput = & $script:_terminalTitleGit -C $gitRoot remote 2>$null
                            $remoteExitCode = $LASTEXITCODE
                            $remotes = @($remoteOutput | Where-Object { $_ })
                            $repoName = ''
                            if ($remoteExitCode -eq 0 -and $remotes.Count -eq 1 -and $remotes[0] -eq 'origin') {
                                $remoteUrl = & $script:_terminalTitleGit -C $gitRoot remote get-url origin 2>$null
                                if ($LASTEXITCODE -eq 0 -and $remoteUrl) {
                                    $repoName = [IO.Path]::GetFileName($remoteUrl.TrimEnd('/', '\'))
                                    if ($repoName.EndsWith('.git', [System.StringComparison]::OrdinalIgnoreCase)) {
                                        $repoName = $repoName.Substring(0, $repoName.Length - 4)
                                    }
                                }
                            }
                            $script:_terminalTitleRepoNames[$gitRoot] = $repoName
                        }
                        if (-not [string]::IsNullOrWhiteSpace($repoName)) {
                            $title = $repoName
                        }
                    }
                }
                if ($title -eq $path -and $title -eq $HOME) {
                    $title = '~'
                } elseif ($title -eq $path -and $title.StartsWith("$HOME\", [System.StringComparison]::OrdinalIgnoreCase)) {
                    $title = "~$($title.Substring($HOME.Length))"
                }
                $script:_terminalTitleLastPath = $path
                $script:_terminalTitleLastTitle = $title
            }
            [System.Console]::Write("`e]0;$title`a`e]1;$title`a`e]2;$title`a")
            [System.Console]::Write("`e]9;9;$path`a")
        }
    }
}

# === Smart cd (falls back to zoxide, like zsh) ===
# Aliases take precedence over functions in PowerShell — must remove the built-in 'cd' alias first.
Remove-Item Alias:cd -Force -ErrorAction SilentlyContinue
function cd {
    if ($args.Count -eq 0) {
        if ($script:_hasZoxide) { zi } else { Set-Location ~ }
        return
    }

    try {
        Set-Location @args -ErrorAction Stop
    } catch {
        if (-not $script:_hasZoxide) {
            Write-Error "cd: no such file or directory: $($args -join ' ')"
            return
        }

        # Tab-completion may prepend .\  — strip it so zoxide can match
        $zArgs = @($args | ForEach-Object { if ($_ -is [string]) { $_ -replace '^\.[\\/]', '' -replace '[\\/]+$', '' } else { $_ } })
        $null = zoxide query -s @zArgs 2>$null
        if ($LASTEXITCODE -eq 0) {
            z @zArgs
        } else {
            Write-Error "cd: no such file or directory: $($args -join ' ')"
        }
    }
}

function gcd {
    param([Parameter(Position = 0)][string]$Repo)

    if ([string]::IsNullOrWhiteSpace($Repo)) {
        Write-Error "Usage: gcd <repo>"
        return
    }

    $inputRepo = $Repo.TrimEnd('/', '\')
    $dir = [IO.Path]::GetFileName($inputRepo)
    if ($dir.EndsWith('.git')) { $dir = $dir.Substring(0, $dir.Length - 4) }

    $githubRepo = ''
    if ($inputRepo -match '^https?://github\.com/([^/]+/[^/]+)') {
        $githubRepo = $Matches[1]
    } elseif ($inputRepo -match '^git@github\.com:([^/]+/[^/]+)') {
        $githubRepo = $Matches[1]
    } elseif ($inputRepo -match '^ssh://git@github\.com/([^/]+/[^/]+)') {
        $githubRepo = $Matches[1]
    } elseif ($inputRepo -match '^[^/:\\]+/[^/:\\]+$') {
        $githubRepo = $inputRepo
    }

    if ($githubRepo.EndsWith('.git')) { $githubRepo = $githubRepo.Substring(0, $githubRepo.Length - 4) }
    if (($githubRepo -split '/').Count -ne 2) { $githubRepo = '' }

    $largeRepoKb = 256000
    if ($env:GCD_LARGE_REPO_KB -match '^\d+$') { $largeRepoKb = [int]$env:GCD_LARGE_REPO_KB }

    $repoSizeKb = $null
    if ($githubRepo -and (Get-Command gh -ErrorAction SilentlyContinue)) {
        $sizeOutput = gh repo view $githubRepo --json diskUsage -q .diskUsage 2>$null
        if ($LASTEXITCODE -eq 0 -and $sizeOutput -match '^\d+$') {
            $repoSizeKb = [int]$sizeOutput
        }
    }

    if ($null -ne $repoSizeKb -and $repoSizeKb -ge $largeRepoKb) {
        Write-Host "Large repo detected: $repoSizeKb KiB. Downloading latest checkout only."
        git clone --filter=blob:none --also-filter-submodules --depth 1 --recurse-submodules --shallow-submodules $inputRepo
        if ($LASTEXITCODE -ne 0) { return }
        Set-Location $dir
        Write-Host "Missing: full history, tags, historical blobs, and full submodule history."
        Write-Host "Download history and tags: git fetch --unshallow --tags"
        Write-Host "Download all missing blobs: git rev-list --objects --all | git cat-file --batch-check='%(objectname)' >`$null"
        Write-Host "Download full submodule history: git submodule foreach --recursive 'git fetch --unshallow --tags || git fetch --tags'"
        return
    }

    git clone --recurse-submodules $inputRepo
    if ($LASTEXITCODE -eq 0) { Set-Location $dir }
}

