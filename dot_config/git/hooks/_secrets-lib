#!/usr/bin/env bash
# Sourced helper for secret-management git hooks.
#
# Public API:
#   secrets_repo_has_git_crypt
#       Exits 0 when .gitattributes mentions filter=git-crypt.
#   secrets_classify_paths <gc_active>
#       Reads paths on stdin, writes "<provider>\t<path>" lines on stdout for
#       paths that belong to a provider. Batches `git check-attr` for the
#       git-crypt provider in a single fork.
#   secrets_blob_is_plaintext <provider> <blob-sha>
#       Exits 0 when the blob is unencrypted; 1 otherwise.
#   secrets_encrypt_file <provider> <path>
#       Encrypts the file in place. Returns 0 on success, 2 when the provider
#       is filter-driven and a plaintext blob means misconfiguration.
#
# Adding a provider: add one case arm in each of the three functions above.

secrets_repo_has_git_crypt() {
  [[ -f .gitattributes ]] && grep -qF 'filter=git-crypt' .gitattributes 2>/dev/null
}

secrets_classify_paths() {
  local gc_active=$1 p line
  local gc_candidates=()
  while IFS= read -r p; do
    [[ -z "$p" ]] && continue
    case "$p" in
      *.ejson) printf 'ejson\t%s\n' "$p" ;;
      *) (( gc_active )) && gc_candidates+=("$p") ;;
    esac
  done
  if (( ${#gc_candidates[@]} > 0 )); then
    while IFS= read -r line; do
      [[ "$line" == *': filter: git-crypt' ]] && \
        printf 'git-crypt\t%s\n' "${line%: filter: git-crypt}"
    done < <(printf '%s\n' "${gc_candidates[@]}" | git check-attr --stdin filter 2>/dev/null)
  fi
}

secrets_blob_is_plaintext() {
  local provider=$1 sha=$2
  case "$provider" in
    ejson)
      git cat-file -p "$sha" 2>/dev/null \
        | grep -oE '"[^_"][^"]*"[[:space:]]*:[[:space:]]*"[^"]*"' \
        | grep -qvE ':[[:space:]]*("EJ\[1:|"")'
      ;;
    git-crypt)
      # Encrypted blobs begin with the magic bytes \0GITCRYPT\0 (10 bytes).
      local hex
      hex=$(git cat-file -p "$sha" 2>/dev/null | head -c 10 | od -An -tx1 2>/dev/null | tr -d ' \n')
      [[ "$hex" != 00474954435259505400* ]]
      ;;
    *)
      return 1
      ;;
  esac
}

secrets_encrypt_file() {
  local provider=$1 file=$2
  case "$provider" in
    ejson) ejson encrypt "$file" >/dev/null ;;
    git-crypt) return 2 ;;
    *) return 1 ;;
  esac
}
