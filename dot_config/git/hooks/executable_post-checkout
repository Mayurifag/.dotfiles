#!/bin/bash
# Post-checkout script to clean merged branches
# Its done in background async in new process to not hold the thread you are on
set -euo pipefail

zero_sha=0000000000000000000000000000000000000000

run_worker() {
  local repo_dir="${1:-}" git_sync new_branch remote_head default

  exec </dev/null >/dev/null 2>&1

  [[ -n "$repo_dir" ]] || return 0
  cd "$repo_dir" || return 0

  git_sync=$(command -v git-sync 2>/dev/null || true)
  [[ -z "$git_sync" && -x "$HOME/.local/bin/git-sync" ]] && git_sync="$HOME/.local/bin/git-sync"
  [[ -n "$git_sync" ]] || return 0

  new_branch=$(git symbolic-ref --quiet --short HEAD) || return 0
  remote_head=$(git symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null) || return 0
  default="${remote_head#refs/remotes/origin/}"
  [[ -n "$default" && "$new_branch" == "$default" ]] || return 0

  git diff --quiet && git diff --cached --quiet || return 0

  "$git_sync"
}

if [[ "${1:-}" == "--worker" ]]; then
  run_worker "${2:-}"
  exit $?
fi

script_path="$0"
[[ "$script_path" == /* ]] || script_path="$PWD/$script_path"

hooks_dir="${script_path%/*}"
hook_name="${script_path##*/}"

run_chain() {
  local rc=0 git_dir="${GIT_DIR:-.git}" candidate
  [[ "$git_dir" == /* ]] || git_dir="$PWD/$git_dir"

  for candidate in "$PWD/.githooks/$hook_name" "$git_dir/hooks/$hook_name"; do
    if [[ -x "$candidate" && "$candidate" != "$hooks_dir/$hook_name" ]]; then
      "$candidate" "$@" || rc=$?
    fi
  done

  return $rc
}

cleanup() {
  local rc=$?
  run_chain "$@" || rc=$?
  exit "$rc"
}

start_worker() {
  local repo_dir="$PWD"

  (
    cd / || true
    bash -c 'bash "$1" --worker "$2" &' bash "$script_path" "$repo_dir" </dev/null >/dev/null 2>&1 &
  )
}

trap 'cleanup "$@"' EXIT

[[ "${3:-0}" == "1" ]] || exit 0
[[ "${1:-}" != "$zero_sha" ]] || exit 0

start_worker
