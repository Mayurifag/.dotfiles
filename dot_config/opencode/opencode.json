{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "enabled_providers": ["openai", "opencode-go"],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "options": {
            "reasoningEffort": "medium"
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium"
            }
          }
        }
      }
    }
  },
  "permission": "allow",
  "formatter": {
    "prettier": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".css", ".html"]
    },
    "shfmt": {
      "command": ["shfmt", "-w", "$FILE"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "dprint": {
      "command": ["dprint", "fmt", "--config", "~/.dprint.json", "$FILE"],
      "extensions": [".json", ".jsonc", ".md", ".yaml", ".yml"]
    },
    "taplo": {
      "command": ["taplo", "format", "$FILE"],
      "extensions": [".toml"]
    }
  }
}
