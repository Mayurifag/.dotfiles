{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "permission": "allow",
  "formatter": {
    "prettier": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".css", ".html"]
    },
    "shfmt": {
      "command": ["shfmt", "-w", "$FILE"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "dprint": {
      "command": ["dprint", "fmt", "--config", "~/.dprint.json", "$FILE"],
      "extensions": [".json", ".jsonc", ".md", ".yaml", ".yml"]
    },
    "taplo": {
      "command": ["taplo", "format", "$FILE"],
      "extensions": [".toml"]
    }
  }
}
