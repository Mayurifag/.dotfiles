{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.3-codex-spark",
  "default_agent": "build",
  "enabled_providers": ["openai"],
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh",
      "description": "Build (GPT 5.5 Fast XHigh)"
    },
    "fast": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex-spark",
      "description": "Fast (GPT 5.3 Codex Spark)"
    },
    "title": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "plan": {
      "disable": true
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    }
  },
  "plugin": ["opencode-notify", "@franlol/opencode-md-table-formatter", "opencode-pty"],
  "command": {
    "ogc-usage": {
      "template": "Call the ogc_usage tool exactly once and return its output directly.",
      "description": "Show OpenCode Go usage"
    }
  },
  "lsp": {
    "toml": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    }
  },
  "permission": "allow",
  "formatter": {
    "prettier": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".css", ".html"]
    },
    "shfmt": {
      "command": ["shfmt", "-w", "$FILE"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "dprint": {
      "command": ["dprint", "fmt", "--config", "$HOME/.dprint.json", "$FILE"],
      "extensions": [".json", ".jsonc", ".md", ".yaml", ".yml"]
    },
    "taplo": {
      "command": ["taplo", "format", "$FILE"],
      "extensions": [".toml"]
    }
  }
}
