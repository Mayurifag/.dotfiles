{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.3-codex-spark",
  "default_agent": "build",
  "enabled_providers": ["openai"],
  "autoupdate": false,
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "description": "Build (GPT 5.5 Medium)"
    },
    "fast": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex-spark",
      "description": "Fast (GPT 5.3 Codex Spark)"
    },
    "title": {
      "model": "openai/gpt-5.3-codex-spark",
      "options": {
        "reasoningEffort": "low"
      }
    },
    "plan": {
      "disable": true
    }
  },
  "plugin": ["opencode-notify", "@franlol/opencode-md-table-formatter", "opencode-pty"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "browser-mcp": {
      "type": "local",
      "command": ["browser-mcp", "--server"],
      "enabled": true,
      "environment": {
        "CHROME_DEVTOOLS_MCP_NO_USAGE_STATISTICS": "1",
        "CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS": "1"
      }
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa",
      "headers": {
        "x-api-key": "{{ (joinPath .chezmoi.sourceDir "keys.ejson" | ejsonDecrypt).exa_api_key }}"
      },
      "enabled": true
    }
  },
  "lsp": {
    "json": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "yaml": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "ansible": {
      "command": ["ansible-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".js", ".jsx", ".ts", ".tsx"]
    },
    "oxlint": {
      "command": ["oxlint", "--lsp"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".vue", ".astro", ".svelte"]
    },
    "css": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css"]
    },
    "html": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html"]
    },
    "dockerfile": {
      "command": ["docker-langserver", "--stdio"],
      "extensions": [".dockerfile", "Dockerfile"]
    },
    "lua-ls": {
      "command": ["mise", "exec", "--", "lua-language-server"],
      "extensions": [".lua"]
    },
    "toml": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    }
  },
  "permission": "allow",
  "formatter": {
    "prettier": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".css", ".html"]
    },
    "shfmt": {
      "command": ["shfmt", "-w", "$FILE"],
      "extensions": [".sh", ".bash", ".zsh"]
    },
    "dprint": {
      "command": ["dprint", "fmt", "--config", "$HOME/.dprint.json", "$FILE"],
      "extensions": [".json", ".jsonc", ".md", ".yaml", ".yml"]
    },
    "taplo": {
      "command": ["taplo", "format", "$FILE"],
      "extensions": [".toml"]
    }
  }
}
