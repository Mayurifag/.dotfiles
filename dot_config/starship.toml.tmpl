# Starship — cross-shell prompt config
# Managed by chezmoi → deploys to ~/.config/starship.toml

{{ if eq .chezmoi.os "windows" -}}
format = "$character$directory\u001b7$fill$git_branch$git_status$git_metrics$git_state$cmd_duration\u001b8"
{{- else -}}
format = "$character$directory"
right_format = "$git_branch$git_status$git_metrics$git_state$cmd_duration"
{{- end }}
add_newline = false

[character]
success_symbol = "[▲](white)"
error_symbol = "[△](red)"

[directory]
truncation_length = 4
truncate_to_repo = false

[git_branch]
format = "[$symbol$branch]($style) "
symbol = " "

[git_status]
format = "([$all_status$ahead_behind]($style) )"

[cmd_duration]
min_time = 2_000
format = "[$duration]($style) "

