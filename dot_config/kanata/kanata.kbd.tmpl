;; kanata.kbd — cross-platform key remapping
;; Managed by chezmoi — edit at ~/.local/share/chezmoi/dot_config/kanata/kanata.kbd.tmpl
;;
;; Deploys to: ~/.config/kanata/kanata.kbd
;; Platforms:  Linux (systemd user service) + Windows (registry Run key via kanata_gui)
;;
;; RAlt typography layer: 18 Birman layout unicode mappings.
;; CapsLock is in defsrc with passthrough (_) so it reaches AHK on Windows
;; without needing process-unmapped-keys (which would re-inject all keys via
;; SendInput and break espanso's Win32Source keystroke detection).

(defcfg
{{- if eq .chezmoi.os "windows" }}
  windows-altgr cancel-lctl-press
{{- end }}
)

(defsrc
  caps  ralt  -  2  3  4  5  6  7  8  9  0  =  r  t  p  /  h  ,  .
)

(defalias
  emdash (unicode —)
  sq2    (unicode ²)
  sq3    (unicode ³)
  qtr    (unicode ¼)
  half   (unicode ½)
  tqtr   (unicode ¾)
  ique   (unicode ¿)
  inf    (unicode ∞)
  larr   (unicode ←)
  rarr   (unicode →)
  pm     (unicode ±)
  reg    (unicode ®)
  tm     (unicode ™)
  ost    (unicode Ø)
  elip   (unicode …)
  rub    (unicode ₽)
  laq    (unicode «)
  raq    (unicode »)
)

(deflayer default
  _  (layer-while-held typography)  _  _  _  _  _  _  _  _  _  _  _  _  _  _  _  _  _  _
)

(deflayer typography
  _  _  @emdash  @sq2  @sq3  @qtr  @half  @tqtr  @ique  @inf  @larr  @rarr  @pm  @reg  @tm  @ost  @elip  @rub  @laq  @raq
)
