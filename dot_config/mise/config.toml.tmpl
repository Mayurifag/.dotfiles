[% end -%]
usage = "3.3.0"
uv = "0.11.15"
bun = "1.3.14"
chezmoi = "2.70.4"
fzf = "0.72.0"
lazygit = "0.61.1"
starship = "1.25.1"
codex = "0.133.0"
opencode = "1.17.3"
markdownlint-cli2 = "0.22.1"
prettier = "3.8.3"
dust = "1.2.4"
zoxide = "0.9.9"
tlrc = "1.13.1"
eza = "0.23.4"
ripgrep = "15.1.0"
sd = "1.1.0"
dprint = "0.54.0"
taplo = "0.10.0"
lua-language-server = "3.18.2"
lazydocker = "0.25.2"
ejson = "1.5.4"
