## System utilities (zsh-only)
alias free='free -m'
alias net="ping ya.ru | grep -E --only-match --color=never '[0-9\.]+ ms'"
alias bench-network="curl -sL yabs.sh | bash -s -- -fdg"
alias y='yay'
alias yabs='curl -sL https://yabs.sh | bash'

## Translation (zsh-only)
# https://github.com/soimort/translate-shell
alias tru='trans :ru'
alias ten='trans :en'

## Antidote/Brew/Desktop helpers (zsh/Linux-only)
alias bundleantidote='antidote bundle < ~/zsh/plugins.txt > ~/zsh/.zsh_plugins.sh'
brewfile() {
  local f; f=$(chezmoi source-path)/install/Brewfile
  brew bundle dump --file="$f" --force --no-vscode
  awk 'NF{print $1}' "$f" | awk '!x[$0]++' | while IFS= read -r t; do grep "^$t " "$f" | sort; done > "$f.tmp" && mv "$f.tmp" "$f"
}
alias updatedesktopdb='update-desktop-database ~/.local/share/applications/'

## macOS-specific (conditional)
if ! if_command_exists gitkraken; then
  alias gitkraken='/Applications/GitKraken.app/Contents/MacOS/GitKraken'
fi
alias gk='(eval "gitkraken --new-window -p \"$(git rev-parse --show-toplevel)\" -l /dev/null >/dev/null 2>&1 &")'
alias g='gk'
