## Chezmoi (zsh-only)
alias czapply='echo "edited a file directly? run: czsrc ~/.thatfile" && chezmoi apply -v && source "$HOME/.zshrc"'
alias czcd='cd "$(chezmoi source-path)"'
alias cdcz='czcd'

## Root (zsh/Linux-only)
alias reboot='sudo reboot'
alias root='sudo -i'

