#!/usr/bin/env python3
import json
import sys
import subprocess


def npm_list_global():
    p = subprocess.run(["npm", "list", "-g", "--depth=0", "--json"], capture_output=True, text=True)
    try:
        deps = json.loads(p.stdout or "{}").get("dependencies") or {}
    except json.JSONDecodeError:
        deps = {}
    return {name: data.get("version") for name, data in deps.items()}


before = npm_list_global()
rc = subprocess.run(["npm", "update", "-g", *sys.argv[1:]]).returncode
after = npm_list_global()
changed = [name for name, version in after.items() if before.get(name) != version]

if not changed:
    print("Nothing updated.")
    raise SystemExit(rc)

for name in changed:
    print(f"{name}: {before.get(name, '(new)')} -> {after[name]}")
raise SystemExit(rc)
