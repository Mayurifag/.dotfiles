USER_SCRIPT_BLOCK_RE = re.compile(rb"//\s*==User(?:Script|Style)==(?P<body>.*?)//\s*==/User(?:Script|Style)==", re.DOTALL)
USER_SCRIPT_NAME_RE = re.compile(rb"@name(?::[a-zA-Z_-]+)?[ \t]+([^\r\n<]{1,200})")
USER_SCRIPT_VERSION_RE = re.compile(rb"@version[ \t]+([^\r\n<]{1,100})")
