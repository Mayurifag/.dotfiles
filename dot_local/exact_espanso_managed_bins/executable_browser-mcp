#!/usr/bin/env node
const child = require("child_process");
const fs = require("fs");
const http = require("http");
const https = require("https");
const os = require("os");
const path = require("path");
const zlib = require("zlib");

const HOST = "127.0.0.1";
const BASE_PORT = 9223;
const PORT_SPAN = 1000;
const START_TIMEOUT = Number(process.env.OPENCODE_BROWSER_MCP_START_TIMEOUT || 3) * 1000;
const TEMPLATE_PROFILE = expandHome(process.env.OPENCODE_BROWSER_MCP_TEMPLATE_PROFILE || "~/.local/share/chezmoi/browser-mcp-template/profile");
const TM_IDS = ["dhdgffkkebhmkfjojejmpbldmpobfkfo", "gcalenpjmijncebpfijmoaglllgpjagf"];
const STYLUS_IDS = ["clngdbkpkpeebahjckkjfobafhncgmne"];
const SETTING_LABELS = { 1: "allow", 2: "block", 3: "ask" };
const USER_BLOCK_RE = /\/\/\s*==User(?:Script|Style)==(?<body>[\s\S]*?)\/\/\s*==\/User(?:Script|Style)==/g;
const NAME_RE = /@name(?::[a-zA-Z_-]+)?[ \t]+([^\r\n<\\]{1,200})/;
const VERSION_RE = /@version[ \t]+([^\r\n<\\]{1,100})/;
const LOCAL_VITE_RE = /^http:\/\/(127\.0\.0\.1|localhost)(:\d+)?\/.*(__vite-plugin-monkey|\/src\/main\.js|\/@vite\/client|vite)/;

function expandHome(value) {
  return value.startsWith("~/") ? path.join(os.homedir(), value.slice(2)) : value;
}

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function repoRoot() {
  try {
    return child.execFileSync("git", ["rev-parse", "--show-toplevel"], { cwd: process.cwd(), encoding: "utf8", stdio: ["ignore", "pipe", "ignore"] }).trim() || process.cwd();
  } catch {
    return process.cwd();
  }
}

function profileDir() {
  return path.resolve(expandHome(process.env.OPENCODE_BROWSER_PROFILE_DIR || path.join(repoRoot(), ".opencode", "browser-mcp-profile")));
}

function port() {
  return process.env.OPENCODE_BROWSER_MCP_PORT ? Number(process.env.OPENCODE_BROWSER_MCP_PORT) : BASE_PORT + (zlib.crc32(Buffer.from(repoRoot())) % PORT_SPAN);
}

function browserUrl(number) {
  return `http://${HOST}:${number}`;
}

function chromePath() {
  if (process.env.OPENCODE_CHROME_PATH) {
    const candidate = expandHome(process.env.OPENCODE_CHROME_PATH);
    if (fs.existsSync(candidate)) return candidate;
    throw new Error(`OPENCODE_CHROME_PATH does not exist: ${candidate}`);
  }

  const candidates = [];
  if (process.platform === "darwin") {
    candidates.push("/Applications/Google Chrome.app/Contents/MacOS/Google Chrome");
    candidates.push(path.join(os.homedir(), "Applications/Google Chrome.app/Contents/MacOS/Google Chrome"));
  } else if (process.platform === "win32") {
    for (const root of [process.env.PROGRAMFILES, process.env["PROGRAMFILES(X86)"], process.env.LOCALAPPDATA]) {
      if (root) candidates.push(path.join(root, "Google", "Chrome", "Application", "chrome.exe"));
    }
  } else {
    for (const name of ["google-chrome", "google-chrome-stable"]) {
      const result = child.spawnSync("sh", ["-c", `command -v ${name}`], { encoding: "utf8" });
      if (result.status === 0 && result.stdout.trim()) candidates.push(result.stdout.trim());
    }
  }

  const found = candidates.find((candidate) => fs.existsSync(candidate));
  if (found) return found;
  throw new Error("Google Chrome not found. Set OPENCODE_CHROME_PATH to the system Chrome executable.");
}

function getJson(url, timeout = 1000) {
  return new Promise((resolve, reject) => {
    const req = http.get(url, { timeout }, (res) => {
      let body = "";
      res.setEncoding("utf8");
      res.on("data", (chunk) => (body += chunk));
      res.on("end", () => {
        try {
          resolve(JSON.parse(body));
        } catch (error) {
          reject(error);
        }
      });
    });
    req.on("timeout", () => req.destroy(new Error(`${url} timed out`)));
    req.on("error", reject);
  });
}

function getText(url, timeout = 5000) {
  return new Promise((resolve, reject) => {
    const client = url.startsWith("https:") ? https : http;
    const req = client.get(url, { timeout }, (res) => {
      if (res.statusCode < 200 || res.statusCode >= 400) {
        res.resume();
        reject(new Error(`${url} returned HTTP ${res.statusCode}`));
        return;
      }
      let body = "";
      res.setEncoding("utf8");
      res.on("data", (chunk) => (body += chunk));
      res.on("end", () => resolve(body));
    });
    req.on("timeout", () => req.destroy(new Error(`${url} timed out`)));
    req.on("error", reject);
  });
}

function userscriptUrlRules(text) {
  const match = text.match(USER_BLOCK_RE)?.[0] || "";
  const values = (key) => [...match.matchAll(new RegExp(`^//\\s*@${key}\\s+(.+)$`, "gim"))].map((item) => item[1].trim()).filter(Boolean);
  return { include: [...values("match"), ...values("include")], exclude: [...values("exclude"), ...values("exclude-match")] };
}

function globToRegex(pattern) {
  return new RegExp(`^${pattern.replace(/[.+?^${}()|[\]\\]/g, "\\$&").replace(/\*/g, ".*")}$`);
}

function pageMatchesRules(url, rules) {
  if (!url || !/^https?:/.test(url) || !rules.include.length) return false;
  if (rules.exclude.some((pattern) => globToRegex(pattern).test(url))) return false;
  return rules.include.some((pattern) => pattern === "<all_urls>" || globToRegex(pattern).test(url));
}

async function devtoolsAvailable(number) {
  try {
    await getJson(`${browserUrl(number)}/json/version`);
    return true;
  } catch {
    return false;
  }
}

async function targets(number) {
  try {
    const data = await getJson(`${browserUrl(number)}/json/list`);
    return Array.isArray(data) ? data : [];
  } catch {
    return [];
  }
}

function portFree(number) {
  const net = require("net");
  return new Promise((resolve) => {
    const server = net.createServer();
    server.once("error", () => resolve(false));
    server.once("listening", () => server.close(() => resolve(true)));
    server.listen(number, HOST);
  });
}

function processRows() {
  if (process.platform === "win32") {
    try {
      const out = child.execFileSync("pwsh.exe", ["-NoProfile", "-Command", "Get-CimInstance Win32_Process | Select-Object ProcessId,CommandLine | ConvertTo-Json -Compress"], { encoding: "utf8" });
      const data = JSON.parse(out || "[]");
      return (Array.isArray(data) ? data : [data]).map((item) => [Number(item.ProcessId || 0), item.CommandLine || ""]);
    } catch {
      return [];
    }
  }
  const out = child.execFileSync("ps", ["-axo", "pid=,args="], { encoding: "utf8" });
  return out.split("\n").flatMap((line) => {
    const match = line.trim().match(/^(\d+)\s+(.+)$/);
    return match ? [[Number(match[1]), match[2]]] : [];
  });
}

function dedicatedBrowserPids(profile, number) {
  const resolvedProfile = path.resolve(profile);
  const portArg = number == null ? null : `--remote-debugging-port=${number}`;
  return processRows().filter(([pid, command]) => {
    if (pid === process.pid) return false;
    const hasProfile = command.includes("user-data-dir") && (command.includes(profile) || command.includes(resolvedProfile));
    const hasPort = portArg && command.includes(portArg);
    return hasProfile || hasPort;
  }).map(([pid]) => pid);
}

async function terminateProfile(profile, number) {
  let pids = dedicatedBrowserPids(profile, number);
  if (!pids.length) return;
  if (process.platform === "win32") {
    for (const pid of pids) child.spawnSync("taskkill", ["/PID", String(pid), "/T"], { stdio: "ignore" });
    await sleep(800);
    for (const pid of dedicatedBrowserPids(profile, number)) child.spawnSync("taskkill", ["/PID", String(pid), "/T", "/F"], { stdio: "ignore" });
    await waitForBrowserExit(profile, number);
    return;
  }
  for (const pid of pids) {
    try {
      process.kill(pid, "SIGTERM");
    } catch {}
  }
  const deadline = Date.now() + 2000;
  while (Date.now() < deadline && (dedicatedBrowserPids(profile, number).length || (number != null && !(await portFree(number))))) await sleep(100);
  for (const pid of dedicatedBrowserPids(profile, number)) {
    try {
      process.kill(pid, "SIGKILL");
    } catch {}
  }
  await waitForBrowserExit(profile, number);
}

async function waitForBrowserExit(profile, number) {
  const deadline = Date.now() + 5000;
  while (Date.now() < deadline) {
    if (!dedicatedBrowserPids(profile, number).length && (number == null || (await portFree(number)))) return;
    await sleep(100);
  }
  const pids = dedicatedBrowserPids(profile, number);
  const portBusy = number != null && !(await portFree(number));
  throw new Error(`Chrome did not fully close${pids.length ? `; remaining pids: ${pids.join(",")}` : ""}${portBusy ? `; port still busy: ${HOST}:${number}` : ""}`);
}

function readJson(file) {
  try {
    return JSON.parse(fs.readFileSync(file, "utf8"));
  } catch {
    return null;
  }
}

function writeJson(file, data) {
  fs.mkdirSync(path.dirname(file), { recursive: true });
  const tmp = `${file}.tmp`;
  fs.writeFileSync(tmp, JSON.stringify(data));
  fs.renameSync(tmp, file);
}

function preferencesPath(profile) {
  return path.join(profile, "Default", "Preferences");
}

function preferences(profile) {
  return readJson(preferencesPath(profile)) || {};
}

function ensureLoopback(profile) {
  const file = preferencesPath(profile);
  const data = readJson(file);
  if (data === null && fs.existsSync(file)) throw new Error(`Chrome Preferences is not valid JSON: ${file}`);
  const prefs = data || {};
  prefs.profile ||= {};
  prefs.profile.default_content_setting_values ||= {};
  prefs.profile.default_content_setting_values.loopback_network = 1;
  writeJson(file, prefs);
}

async function resetProfile(profile, number) {
  const template = path.resolve(TEMPLATE_PROFILE);
  if (!fs.existsSync(template)) throw new Error(`browser profile template missing: ${template}. Regenerate it from ${path.join(path.dirname(template), "GENERATE.md")}`);
  if (path.resolve(profile) === template) throw new Error("refusing to launch with the template profile directly");
  await terminateProfile(profile, number);
  fs.rmSync(profile, { recursive: true, force: true });
  fs.mkdirSync(path.dirname(profile), { recursive: true });
  fs.cpSync(template, profile, { recursive: true, verbatimSymlinks: true });
  ensureLoopback(profile);
}

function extensionManifest(profile, id) {
  const root = path.join(profile, "Default", "Extensions", id);
  if (!fs.existsSync(root)) return null;
  const versions = fs.readdirSync(root).sort().reverse();
  for (const version of versions) {
    const manifest = readJson(path.join(root, version, "manifest.json"));
    if (manifest) return manifest;
  }
  return null;
}

function extensionInstalled(profile, ids) {
  return ids.some((id) => extensionManifest(profile, id));
}

function tampermonkeyId(profile) {
  const id = TM_IDS.find((candidate) => extensionManifest(profile, candidate));
  if (!id) throw new Error("Tampermonkey is not installed in the browser-mcp template profile");
  return id;
}

function storageScripts(profile, ids) {
  const roots = ids.flatMap((id) => [
    path.join(profile, "Default", "Local Extension Settings", id),
    path.join(profile, "Default", "IndexedDB", `chrome-extension_${id}_0.indexeddb.leveldb`),
    path.join(profile, "Default", "Extension State"),
  ]);
  const scripts = new Map();
  for (const root of roots) scanStorage(root, scripts);
  return [...scripts.values()].sort((a, b) => a.name.localeCompare(b.name));
}

function scanStorage(file, scripts) {
  if (!fs.existsSync(file)) return;
  const stat = fs.statSync(file);
  if (stat.isDirectory()) {
    for (const entry of fs.readdirSync(file)) scanStorage(path.join(file, entry), scripts);
    return;
  }
  if (!stat.isFile() || stat.size > 20 * 1024 * 1024) return;
  const text = fs.readFileSync(file, "utf8");
  const blocks = [...text.matchAll(USER_BLOCK_RE)].map((match) => match.groups.body);
  for (const block of blocks.length ? blocks : [text]) {
    const name = block.match(NAME_RE)?.[1]?.trim().replace(/^"|"$/g, "");
    if (!name || name.startsWith("__MSG_")) continue;
    const version = block.match(VERSION_RE)?.[1]?.trim().replace(/^"|"$/g, "") || null;
    scripts.set(name, { name, version });
  }
}

async function cdp(wsUrl) {
  const ws = new WebSocket(wsUrl);
  await new Promise((resolve, reject) => {
    const timer = setTimeout(() => reject(new Error(`WebSocket connection timed out: ${wsUrl}`)), 3000);
    ws.onopen = () => {
      clearTimeout(timer);
      resolve();
    };
    ws.onerror = reject;
  });
  let id = 0;
  const send = (method, params = {}, timeout = 5000) => new Promise((resolve, reject) => {
    const msg = ++id;
    const timer = setTimeout(() => {
      ws.removeEventListener("message", onMessage);
      reject(new Error(`${method} timed out`));
    }, timeout);
    const onMessage = (event) => {
      const data = JSON.parse(event.data);
      if (data.method === "Page.javascriptDialogOpening") {
        ws.send(JSON.stringify({ id: ++id, method: "Page.handleJavaScriptDialog", params: { accept: true } }));
        return;
      }
      if (data.id !== msg) return;
      clearTimeout(timer);
      ws.removeEventListener("message", onMessage);
      if (data.error) reject(new Error(`${method}: ${JSON.stringify(data.error)}`));
      else resolve(data.result || {});
    };
    ws.addEventListener("message", onMessage);
    ws.send(JSON.stringify({ id: msg, method, params }));
  });
  return { ws, send };
}

async function browserWs(number) {
  return (await getJson(`${browserUrl(number)}/json/version`)).webSocketDebuggerUrl;
}

async function createTarget(number, url) {
  const client = await cdp(await browserWs(number));
  try {
    return (await client.send("Target.createTarget", { url, background: false })).targetId;
  } finally {
    client.ws.close();
  }
}

async function closeTargets(number, ids) {
  const unique = [...new Set(ids.filter(Boolean))];
  if (!unique.length) return;
  const client = await cdp(await browserWs(number)).catch(() => null);
  if (!client) return;
  try {
    for (const targetId of unique) await client.send("Target.closeTarget", { targetId }).catch(() => {});
  } finally {
    client.ws.close();
  }
}

async function targetByPrefix(number, prefix, timeout = 5000) {
  const deadline = Date.now() + timeout;
  while (Date.now() < deadline) {
    const found = (await targets(number)).find((target) => target.type === "page" && target.url?.startsWith(prefix) && target.webSocketDebuggerUrl);
    if (found) return found;
    await sleep(100);
  }
  throw new Error(`DevTools target not found: ${prefix}`);
}

async function evaluate(target, expression, timeout = 5000) {
  const client = await cdp(target.webSocketDebuggerUrl);
  try {
    await client.send("Page.enable", {}, timeout);
    const result = await client.send("Runtime.evaluate", { expression, returnByValue: true }, timeout);
    return Object.prototype.hasOwnProperty.call(result.result || {}, "value") ? result.result.value : result.result?.description;
  } finally {
    client.ws.close();
  }
}

async function reloadUserscriptPages(number, rules) {
  const reloaded = [];
  for (const target of await targets(number)) {
    if (target.type !== "page" || !target.webSocketDebuggerUrl || !pageMatchesRules(target.url, rules)) continue;
    const client = await cdp(target.webSocketDebuggerUrl).catch(() => null);
    if (!client) continue;
    try {
      await client.send("Page.reload", { ignoreCache: true }, 5000);
      reloaded.push(target.url);
    } finally {
      client.ws.close();
    }
  }
  return reloaded;
}

async function requireDevtools(number) {
  if (!(await devtoolsAvailable(number))) throw new Error(`Chrome DevTools is not available at ${browserUrl(number)}. Run browser-mcp --launch <url> first.`);
}

async function installTampermonkey(profile, number, url) {
  await requireDevtools(number);
  const id = tampermonkeyId(profile);
  const rules = await getText(url).then(userscriptUrlRules).catch(() => ({ include: [], exclude: [] }));
  let target = null;
  const deadline = Date.now() + 10000;
  const createdTarget = await createTarget(number, url);
  try {
    while (Date.now() < deadline && !target) {
      try {
        target = await targetByPrefix(number, `chrome-extension://${id}/ask.html`, 2000);
      } catch {
        await sleep(500);
      }
    }
    if (!target) throw new Error(`DevTools target not found: chrome-extension://${id}/ask.html`);
    const expression = `(() => {
      const button = Array.from(document.querySelectorAll("input[type=button],button"))
        .find((el) => /^(Install|Update|Reinstall)$/i.test((el.value || el.innerText || "").trim()));
      if (!button) return { installed: false, text: document.body.innerText.slice(0, 500) };
      button.click();
      return { installed: true };
    })()`;
    let result = null;
    for (let i = 0; i < 25; i++) {
      result = await evaluate(target, expression, 5000);
      if (result?.installed) break;
      await sleep(200);
    }
    if (result?.installed) result.reloadedPages = await reloadUserscriptPages(number, rules);
    return result;
  } finally {
    await closeTargets(number, [createdTarget, target?.id]);
  }
}

async function deleteTampermonkey(profile, number, name) {
  await requireDevtools(number);
  const id = tampermonkeyId(profile);
  const createdTarget = await createTarget(number, `chrome-extension://${id}/options.html#nav=dashboard`);
  let target = null;
  try {
    target = await targetByPrefix(number, `chrome-extension://${id}/options.html`, 5000);
    const expression = `(() => {
      const wanted = ${JSON.stringify(name)};
      window.confirm = () => true;
      const text = (el) => (el.innerText || el.value || el.title || el.getAttribute("aria-label") || "").trim();
      const row = Array.from(document.querySelectorAll("tr.scripttr,tr,.script,.script-row"))
        .find((el) => (el.querySelector("td.script_name span")?.innerText || text(el)).trim() === wanted);
      if (!row) return { deleted: false, reason: "script not found", scripts: Array.from(document.querySelectorAll("tr.scripttr")).map(text).filter(Boolean) };
      const control = Array.from(row.querySelectorAll("button,input,i,a,span"))
        .find((el) => /delete|trash|remove/i.test(text(el)) || /delete|trash|remove/i.test(el.className || ""));
      if (!control) return { deleted: false, reason: "delete control not found", text: text(row).slice(0, 500) };
      control.click();
      return { deleted: true, name: wanted };
    })()`;
    let result = null;
    for (let i = 0; i < 25; i++) {
      result = await evaluate(target, expression, 5000);
      if (result?.deleted) break;
      await sleep(200);
    }
    if (!result?.deleted) return result;
    result.trash = await emptyTampermonkeyTrash(number, id);
    return result;
  } finally {
    await closeTargets(number, [createdTarget, target?.id]);
  }
}

async function emptyTampermonkeyTrash(number, id) {
  const createdTarget = await createTarget(number, `chrome-extension://${id}/options.html#nav=trash`);
  let target = null;
  try {
    target = await targetByPrefix(number, `chrome-extension://${id}/options.html`, 5000);
    const expression = `(() => {
      window.confirm = () => true;
      const text = (el) => (el.innerText || el.value || el.title || el.getAttribute("aria-label") || "").trim();
      const button = Array.from(document.querySelectorAll("button,input,i,a,span"))
        .find((el) => /^Delete all$/i.test(text(el)) || /delete_all|delall/i.test(el.id || ""));
      if (!button) return { emptied: false, reason: "delete all control not found", text: document.body.innerText.slice(0, 500) };
      button.click();
      return { emptied: true };
    })()`;
    let result = null;
    for (let i = 0; i < 25; i++) {
      result = await evaluate(target, expression, 5000);
      if (result?.emptied) return result;
      await sleep(200);
    }
    return result;
  } finally {
    await closeTargets(number, [createdTarget, target?.id]);
  }
}

async function dashboardScripts(profile, number) {
  if (!(await devtoolsAvailable(number))) return null;
  let createdTarget = null;
  let target = null;
  try {
    const id = tampermonkeyId(profile);
    createdTarget = await createTarget(number, `chrome-extension://${id}/options.html#nav=dashboard`);
    target = await targetByPrefix(number, `chrome-extension://${id}/options.html`, 5000);
    for (let i = 0; i < 20; i++) {
      const scripts = await evaluate(target, `(() => Array.from(document.querySelectorAll("tr.scripttr")).map((row) => {
        if (!row.id || row.id.includes("filler")) return null;
        const name = (row.querySelector("td.script_name span")?.innerText || "").trim();
        if (!name || name === "<New userscript>") return null;
        const cells = Array.from(row.querySelectorAll("td")).map((cell) => cell.innerText.trim()).filter(Boolean);
        const version = cells.find((cell) => /^\\d+(?:\\.\\d+)+(?:[-+][\\w.-]+)?$/.test(cell)) || null;
        return { name, version };
      }).filter(Boolean))()`, 5000);
      if (Array.isArray(scripts) && scripts.length) return scripts.sort((a, b) => a.name.localeCompare(b.name));
      await sleep(200);
    }
    return [];
  } catch {
  } finally {
    await closeTargets(number, [createdTarget, target?.id]);
  }
  return null;
}

async function localViteDiagnostics(number) {
  if (!(await devtoolsAvailable(number))) return [];
  const out = [];
  for (const target of await targets(number)) {
    if (target.type !== "page" || !target.url?.startsWith("https://") || !target.webSocketDebuggerUrl) continue;
    const resources = await evaluate(target, `(() => performance.getEntriesByType('resource').map((entry) => ({ url: entry.name, responseStatus: entry.responseStatus || 0 })))()`, 5000).catch(() => []);
    if (!Array.isArray(resources)) continue;
    const urls = resources.filter((entry) => LOCAL_VITE_RE.test(entry.url)).map((entry) => entry.url);
    if (urls.length) out.push({ pageUrl: target.url, localViteUserscriptUrls: urls, failedLocalViteUserscriptRequests: resources.filter((entry) => LOCAL_VITE_RE.test(entry.url) && ![200, 304].includes(entry.responseStatus)) });
  }
  return out;
}

async function status(chrome, profile, number) {
  const prefs = preferences(profile);
  const setting = prefs.profile?.default_content_setting_values?.loopback_network;
  const scripts = await dashboardScripts(profile, number);
  return {
    chrome,
    profile,
    port: number,
    browserUrl: browserUrl(number),
    profileExists: fs.existsSync(profile),
    devtoolsAvailable: await devtoolsAvailable(number),
    portFree: await portFree(number),
    tampermonkeyInstalled: extensionInstalled(profile, TM_IDS),
    stylusInstalled: extensionInstalled(profile, STYLUS_IDS),
    scripts: scripts ?? storageScripts(profile, TM_IDS),
    styles: storageScripts(profile, STYLUS_IDS),
    loopbackNetworkPermissions: { default: setting == null ? null : { setting, label: SETTING_LABELS[setting] || String(setting) } },
    localViteUserscriptDiagnostics: await localViteDiagnostics(number),
  };
}

async function launchBrowser(chrome, profile, number, url) {
  await terminateProfile(profile, number);
  if (!(await portFree(number))) throw new Error(`Port ${HOST}:${number} is already in use. Run browser-mcp --close or set OPENCODE_BROWSER_MCP_PORT to a free port.`);
  if (path.resolve(profile) === path.resolve(TEMPLATE_PROFILE) && process.env.OPENCODE_BROWSER_MCP_ALLOW_TEMPLATE_PROFILE === "1") {
    fs.mkdirSync(profile, { recursive: true });
    ensureLoopback(profile);
  } else {
    await resetProfile(profile, number);
  }
  const args = [
    `--remote-debugging-address=${HOST}`,
    `--remote-debugging-port=${number}`,
    `--user-data-dir=${profile}`,
    "--no-first-run",
    "--no-default-browser-check",
    "--disable-session-crashed-bubble",
    "--window-size=1280,900",
    "--new-window",
    url,
  ];
  if (process.platform === "darwin" && !process.env.OPENCODE_CHROME_PATH) child.spawn("open", ["-g", "-n", "-a", "Google Chrome", "--args", ...args], { detached: true, stdio: "ignore" }).unref();
  else child.spawn(chrome, args, { detached: true, stdio: "ignore" }).unref();
  const deadline = Date.now() + START_TIMEOUT;
  while (Date.now() < deadline) {
    if (await devtoolsAvailable(number)) return;
    await sleep(200);
  }
  await terminateProfile(profile, number);
  throw new Error(`Chrome did not expose DevTools at ${browserUrl(number)} within ${START_TIMEOUT / 1000}s`);
}

function valueAfter(args, flag) {
  const index = args.indexOf(flag);
  if (index === -1) return null;
  if (!args[index + 1] || args[index + 1].startsWith("--")) throw new Error(`${flag} requires a value`);
  return args[index + 1];
}

function stripFlags(args) {
  const withValues = new Set(["--launch", "--tampermonkey-install", "--tampermonkey-delete"]);
  const withoutValues = new Set(["--server", "--status", "--check", "--close"]);
  const out = [];
  for (let i = 0; i < args.length; i++) {
    if (withValues.has(args[i])) i++;
    else if (!withoutValues.has(args[i])) out.push(args[i]);
  }
  return out;
}

function runMcp(profile, number, args) {
  return new Promise((resolve, reject) => {
    const env = { ...process.env, NODE_OPTIONS: `${process.env.NODE_OPTIONS || ""} --no-warnings`.trim() };
    const proc = child.spawn("npx", ["-y", "chrome-devtools-mcp@latest", `--browserUrl=${browserUrl(number)}`, "--no-usage-statistics", "--no-performance-crux", ...stripFlags(args)], { stdio: "inherit", env });
    let exiting = false;
    const finish = async (code, signal) => {
      if (exiting) return;
      exiting = true;
      try {
        await terminateProfile(profile, number);
        resolve(code ?? (signal ? 128 : 0));
      } catch (error) {
        reject(error);
      }
    };
    for (const signal of ["SIGINT", "SIGTERM"]) {
      process.once(signal, () => {
        proc.kill(signal);
      });
    }
    proc.on("error", reject);
    proc.on("exit", finish);
  });
}

async function main() {
  const args = process.argv.slice(2);
  const profile = profileDir();
  const number = port();
  if (args.includes("--close")) {
    await terminateProfile(profile, number);
    return 0;
  }

  const launchUrl = valueAfter(args, "--launch");
  const installUrl = valueAfter(args, "--tampermonkey-install");
  const deleteName = valueAfter(args, "--tampermonkey-delete");
  const needsChrome = args.includes("--status") || args.includes("--check") || launchUrl || installUrl || deleteName;
  const chrome = needsChrome ? chromePath() : null;

  if (args.includes("--status") || args.includes("--check")) console.log(JSON.stringify(await status(chrome, profile, number), null, 2));
  else if (launchUrl) {
    await launchBrowser(chrome, profile, number, launchUrl);
    console.log(JSON.stringify(await status(chrome, profile, number), null, 2));
  } else if (installUrl) console.log(JSON.stringify(await installTampermonkey(profile, number, installUrl), null, 2));
  else if (deleteName) console.log(JSON.stringify(await deleteTampermonkey(profile, number, deleteName), null, 2));
  else {
    return await runMcp(profile, number, args);
  }
  return 0;
}

main().then((code) => process.exit(code)).catch((error) => {
  console.error(`browser-mcp: ${error.message}`);
  process.exit(1);
});
