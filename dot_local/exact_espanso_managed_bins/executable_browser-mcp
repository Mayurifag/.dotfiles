def eprint(*args):
    print(*args, file=sys.stderr)


def repo_root():
    result = subprocess.run(["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True, cwd=Path.cwd())
    if result.returncode == 0 and result.stdout.strip():
        return Path(result.stdout.strip())
    return Path.cwd()


def profile_dir():
    override = os.environ.get("OPENCODE_BROWSER_PROFILE_DIR")
    if override:
        return Path(override).expanduser().resolve()
    return (repo_root() / ".opencode" / "browser-mcp-profile").resolve()


def port():
    override = os.environ.get("OPENCODE_BROWSER_MCP_PORT")
    if override:
        return int(override)
    return BASE_PORT + zlib.crc32(str(repo_root()).encode("utf-8")) % PORT_SPAN


def devtools_url(host, number):
    return f"http://{host}:{number}"


def chrome_path():
    override = os.environ.get("OPENCODE_CHROME_PATH")
    if override:
        path = Path(override).expanduser()
        if path.exists():
            return str(path)
        raise RuntimeError(f"OPENCODE_CHROME_PATH does not exist: {path}")

    system = platform.system()
    candidates = []
    if system == "Darwin":
        candidates = [
            "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
            str(Path.home() / "Applications/Google Chrome.app/Contents/MacOS/Google Chrome"),
        ]
    elif system == "Windows":
        for root in (os.environ.get("PROGRAMFILES"), os.environ.get("PROGRAMFILES(X86)"), os.environ.get("LOCALAPPDATA")):
            if root:
                candidates.append(str(Path(root) / "Google" / "Chrome" / "Application" / "chrome.exe"))
    else:
        for name in ("google-chrome", "google-chrome-stable"):
            found = shutil.which(name)
            if found:
                candidates.append(found)

    for candidate in candidates:
        if Path(candidate).exists():
            return candidate
    raise RuntimeError("Google Chrome not found. Set OPENCODE_CHROME_PATH to the system Chrome executable.")


def port_free(host, number):
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            sock.bind((host, number))
        except OSError:
            return False
    return True


def process_rows():
    system = platform.system()
    if system == "Windows":
        command = [
            "pwsh.exe",
            "-NoProfile",
            "-Command",
            "Get-CimInstance Win32_Process | Select-Object ProcessId,Name,CommandLine | ConvertTo-Json -Compress",
        ]
        result = subprocess.run(command, capture_output=True, text=True)
        if result.returncode != 0 or not result.stdout.strip():
            return []
        data = json.loads(result.stdout)
        if isinstance(data, dict):
            data = [data]
        return [(int(p.get("ProcessId") or 0), p.get("Name") or "", p.get("CommandLine") or "") for p in data]

    result = subprocess.run(["ps", "-axo", "pid=,comm=,args="], capture_output=True, text=True)
    rows = []
    for line in result.stdout.splitlines():
        parts = line.strip().split(None, 2)
        if len(parts) == 3 and parts[0].isdigit():
            rows.append((int(parts[0]), parts[1], parts[2]))
    return rows


def profile_processes(profile):
    needle = str(profile)
    matches = []
    for pid, name, command in process_rows():
        if pid == os.getpid():
            continue
        if needle in command and "user-data-dir" in command:
            matches.append((pid, name, command))
    return matches


def close_devtools_targets(number):
    targets = devtools_targets(number)
    for target in targets:
        if target.get("type") != "page" or not target.get("id"):
            continue
        try:
            urllib.request.urlopen(f"{devtools_url(HOST, number)}/json/close/{urllib.parse.quote(target['id'])}", timeout=1).close()
        except (urllib.error.URLError, TimeoutError):
            pass


def devtools_targets(number):
    try:
        with urllib.request.urlopen(f"{devtools_url(HOST, number)}/json/list", timeout=1) as response:
            data = json.loads(response.read().decode("utf-8"))
            return data if isinstance(data, list) else []
    except (urllib.error.URLError, TimeoutError, json.JSONDecodeError):
        return []


def terminate_profile_processes(profile, number=None):
    matches = profile_processes(profile)
    if not matches:
        return
    if number is not None and platform.system() != "Darwin":
        close_devtools_targets(number)
        time.sleep(0.2)
        matches = profile_processes(profile)
        if not matches:
            return
    if platform.system() == "Windows":
        for pid, _, _ in matches:
            subprocess.run(["taskkill", "/PID", str(pid), "/T"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        time.sleep(1)
        for pid, _, _ in profile_processes(profile):
            subprocess.run(["taskkill", "/PID", str(pid), "/T", "/F"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return
    for pid, _, _ in matches:
        try:
            os.kill(pid, signal.SIGTERM)
        except ProcessLookupError:
            pass
    deadline = time.time() + 2
    while time.time() < deadline and profile_processes(profile):
        time.sleep(0.1)
    for pid, _, _ in profile_processes(profile):
        try:
            os.kill(pid, signal.SIGKILL)
        except ProcessLookupError:
            pass


def devtools_available(host, number):
    url = f"{devtools_url(host, number)}/json/version"
    try:
        with urllib.request.urlopen(url, timeout=1) as response:
            json.loads(response.read().decode("utf-8"))
            return True
    except (urllib.error.URLError, TimeoutError, json.JSONDecodeError):
        return False


def wait_for_chrome(host, number):
    url = f"{devtools_url(host, number)}/json/version"
    deadline = time.time() + START_TIMEOUT
    last_error = None
    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=1) as response:
                json.loads(response.read().decode("utf-8"))
                return
        except (urllib.error.URLError, TimeoutError, json.JSONDecodeError) as exc:
            last_error = exc
            time.sleep(0.2)
    raise RuntimeError(f"Chrome did not expose DevTools at {url} within {START_TIMEOUT:g}s: {last_error}")


def popen_detached(command):
    kwargs = {"stdin": subprocess.DEVNULL, "stdout": subprocess.DEVNULL, "stderr": subprocess.DEVNULL}
    if platform.system() == "Windows":
        kwargs["creationflags"] = subprocess.CREATE_NEW_PROCESS_GROUP | subprocess.DETACHED_PROCESS
    else:
        kwargs["start_new_session"] = True
    return subprocess.Popen(command, **kwargs)


def launch_chrome(chrome, profile, number, url):
    args = [
        f"--remote-debugging-address={HOST}",
        f"--remote-debugging-port={number}",
        f"--user-data-dir={profile}",
        "--no-first-run",
        "--no-default-browser-check",
        "--disable-session-crashed-bubble",
        "--window-size=1280,900",
        "--new-window",
        url,
    ]
    if platform.system() == "Darwin" and not os.environ.get("OPENCODE_CHROME_PATH"):
        return popen_detached(["open", "-g", "-n", "-a", "Google Chrome", "--args", *args])
    return popen_detached([chrome, *args])


def mcp_command(number, passthrough):
    return [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        f"--browserUrl={devtools_url(HOST, number)}",
        "--no-usage-statistics",
        "--no-performance-crux",
        *passthrough,
    ]


def mcp_env():
    env = os.environ.copy()
    options = env.get("NODE_OPTIONS", "")
    if "--no-warnings" not in options:
        env["NODE_OPTIONS"] = f"{options} --no-warnings".strip()
    return env


def read_json(path):
    try:
        with path.open("r", encoding="utf-8") as handle:
            return json.load(handle)
    except (OSError, json.JSONDecodeError):
        return None


def write_json(path, data):
    path.parent.mkdir(parents=True, exist_ok=True)
    temp = path.with_name(f"{path.name}.tmp")
    with temp.open("w", encoding="utf-8") as handle:
        json.dump(data, handle, separators=(",", ":"))
    temp.replace(path)


def preferences_path(profile):
    return profile / "Default" / "Preferences"


def preferences(profile):
    data = read_json(preferences_path(profile))
    return data if isinstance(data, dict) else {}


def loopback_network_exceptions(profile):
    exceptions = (
        preferences(profile)
        .get("profile", {})
        .get("content_settings", {})
        .get("exceptions", {})
        .get("loopback_network", {})
    )
    return exceptions if isinstance(exceptions, dict) else {}


def setting_label(setting):
    return SETTING_LABELS.get(setting, str(setting))


def loopback_network_permissions(profile):
    data = preferences(profile)
    profile_data = data.get("profile", {}) if isinstance(data.get("profile"), dict) else {}
    defaults = profile_data.get("default_content_setting_values", {}) if isinstance(profile_data.get("default_content_setting_values"), dict) else {}
    default = defaults.get("loopback_network")
    return {
        "default": {"setting": default, "label": setting_label(default)} if default is not None else None,
        "exceptions": [
            {"pattern": pattern, "setting": value.get("setting"), "label": setting_label(value.get("setting"))}
            for pattern, value in sorted(loopback_network_exceptions(profile).items())
            if isinstance(value, dict)
        ],
    }


def ensure_loopback_network_default(profile):
    path = preferences_path(profile)
    data = read_json(path)
    if data is None:
        if path.exists():
            raise RuntimeError(f"Chrome Preferences is not valid JSON: {path}")
        data = {}
    profile_data = data.setdefault("profile", {})
    defaults = profile_data.setdefault("default_content_setting_values", {})
    if defaults.get("loopback_network") == 1:
        return
    defaults["loopback_network"] = 1
    write_json(path, data)


def extension_manifest(profile, extension_id):
    root = profile / "Default" / "Extensions" / extension_id
    if not root.is_dir():
        return None
    manifests = sorted(root.glob("*/manifest.json"), key=lambda path: path.parent.name, reverse=True)
    if not manifests:
        return None
    data = read_json(manifests[0])
    if not isinstance(data, dict):
        return None
    return data


def extension_settings(profile, extension_id):
    return preferences(profile).get("extensions", {}).get("settings", {}).get(extension_id, {}) or {}


def websocket_frame(payload):
    data = payload.encode("utf-8")
    header = bytearray([0x81])
    length = len(data)
    if length < 126:
        header.append(0x80 | length)
    elif length < 65536:
        header.extend([0x80 | 126, (length >> 8) & 0xFF, length & 0xFF])
    else:
        header.append(0x80 | 127)
        header.extend(length.to_bytes(8, "big"))
    mask = secrets.token_bytes(4)
    return bytes(header) + mask + bytes(byte ^ mask[index % 4] for index, byte in enumerate(data))


def recv_exact(sock, count):
    data = b""
    while len(data) < count:
        chunk = sock.recv(count - len(data))
        if not chunk:
            raise RuntimeError("WebSocket closed")
        data += chunk
    return data


def websocket_recv(sock):
    first, second = recv_exact(sock, 2)
    opcode = first & 0x0F
    length = second & 0x7F
    if length == 126:
        length = int.from_bytes(recv_exact(sock, 2), "big")
    elif length == 127:
        length = int.from_bytes(recv_exact(sock, 8), "big")
    if second & 0x80:
        mask = recv_exact(sock, 4)
        payload = bytes(byte ^ mask[index % 4] for index, byte in enumerate(recv_exact(sock, length)))
    else:
        payload = recv_exact(sock, length)
    if opcode == 8:
        raise RuntimeError("WebSocket closed")
    return payload.decode("utf-8", "ignore")


def cdp_call(ws_url, method, params=None):
    parsed = urllib.parse.urlparse(ws_url)
    host = parsed.hostname or HOST
    number = parsed.port or (443 if parsed.scheme == "wss" else 80)
    path = parsed.path + (f"?{parsed.query}" if parsed.query else "")
    raw_sock = socket.create_connection((host, number), timeout=1)
    sock = ssl.create_default_context().wrap_socket(raw_sock, server_hostname=host) if parsed.scheme == "wss" else raw_sock
    with sock:
        key = base64.b64encode(secrets.token_bytes(16)).decode("ascii")
        request = (
            f"GET {path} HTTP/1.1\r\n"
            f"Host: {host}:{number}\r\n"
            "Upgrade: websocket\r\n"
            "Connection: Upgrade\r\n"
            f"Sec-WebSocket-Key: {key}\r\n"
            "Sec-WebSocket-Version: 13\r\n\r\n"
        )
        sock.sendall(request.encode("ascii"))
        response = b""
        while b"\r\n\r\n" not in response:
            response += sock.recv(4096)
        accept = base64.b64encode(hashlib.sha1((key + "258EAFA5-E914-47DA-95CA-C5AB0DC85B11").encode("ascii")).digest()).decode("ascii")
        if b" 101 " not in response.split(b"\r\n", 1)[0] or accept.encode("ascii") not in response:
            raise RuntimeError("DevTools WebSocket handshake failed")
        sock.sendall(websocket_frame(json.dumps({"id": 1, "method": method, "params": params or {}})))
        deadline = time.time() + 1
        while time.time() < deadline:
            message = json.loads(websocket_recv(sock))
            if message.get("id") == 1:
                return message
    return {}


def evaluate_target(target, expression):
    try:
        response = cdp_call(target["webSocketDebuggerUrl"], "Runtime.evaluate", {"expression": expression, "returnByValue": True})
    except (KeyError, OSError, RuntimeError, TimeoutError, json.JSONDecodeError):
        return None
    return response.get("result", {}).get("result", {}).get("value")


def local_vite_userscript_diagnostics(profile, number):
    if not devtools_available(HOST, number):
        return []
    expression = r"""
(() => {
  const localVite = /^http:\/\/(127\.0\.0\.1|localhost)(:\d+)?\/.*(__vite-plugin-monkey|\/src\/main\.js|\/@vite\/client|vite)/;
  const resources = performance.getEntriesByType('resource')
    .filter((entry) => localVite.test(entry.name))
    .map((entry) => ({
      url: entry.name,
      initiatorType: entry.initiatorType,
      duration: entry.duration,
      transferSize: entry.transferSize,
      decodedBodySize: entry.decodedBodySize,
      responseStatus: entry.responseStatus || 0,
    }));
  const domUrls = Array.from(document.querySelectorAll('[src],[href]'))
    .map((element) => element.src || element.href)
    .filter((url) => localVite.test(url));
  return { resources, domUrls };
})()
"""
    diagnostics = []
    for target in devtools_targets(number):
        url = target.get("url") or ""
        if target.get("type") != "page" or not url.startswith("https://"):
            continue
        data = evaluate_target(target, expression)
        if not isinstance(data, dict):
            continue
        resources = data.get("resources") if isinstance(data.get("resources"), list) else []
        dom_urls = data.get("domUrls") if isinstance(data.get("domUrls"), list) else []
        local_urls = sorted({entry.get("url") for entry in resources if entry.get("url")} | set(dom_urls))
        if not local_urls:
            continue
        resource_urls = {entry.get("url") for entry in resources if entry.get("url")}
        pending_or_failed = [entry for entry in resources if entry.get("responseStatus") not in (200, 304)]
        pending_or_failed.extend({"url": candidate, "initiatorType": "dom", "responseStatus": 0} for candidate in dom_urls if candidate not in resource_urls)
        diagnostics.append(
            {
                "pageUrl": url,
                "localViteUserscriptUrls": [candidate for candidate in local_urls if LOCAL_VITE_USERSCRIPT_RE.search(candidate)],
                "pendingOrFailedLocalViteUserscriptRequests": pending_or_failed,
                "possibleIssue": "Chrome loopback/local-network permission may be missing for this HTTPS origin" if pending_or_failed else None,
            }
        )
    return diagnostics


def extension_enabled(settings):
    state = settings.get("state")
    return state == 1 if state is not None else None


def user_script_storage_dirs(profile, extension_id):
    default = profile / "Default"
    candidates = [
        default / "Local Extension Settings" / extension_id,
        default / "IndexedDB" / f"chrome-extension_{extension_id}_0.indexeddb.leveldb",
        default / "Extension State",
    ]
    return [path for path in candidates if path.exists()]


def user_script_metadata(profile, extension_id):
    scripts = {}
    for storage_dir in user_script_storage_dirs(profile, extension_id):
        files = [storage_dir] if storage_dir.is_file() else storage_dir.rglob("*")
        for path in files:
            if not path.is_file():
                continue
            try:
                if path.stat().st_size > 20 * 1024 * 1024:
                    continue
                data = path.read_bytes()
            except OSError:
                continue
            blocks = [match.group("body") for match in USER_SCRIPT_BLOCK_RE.finditer(data)] or [data]
            for block in blocks:
                name_match = USER_SCRIPT_NAME_RE.search(block)
                if not name_match:
                    continue
                name = name_match.group(1).decode("utf-8", "ignore").strip().strip('"')
                if name and not name.startswith("__MSG_"):
                    version_match = USER_SCRIPT_VERSION_RE.search(block)
                    version = version_match.group(1).decode("utf-8", "ignore").strip().strip('"') if version_match else None
                    scripts[name] = {"name": name, "version": version}
    return sorted(scripts.values(), key=lambda script: script["name"].casefold())


def user_script_manager_status(profile):
    managers = []
    for key, manager in USER_SCRIPT_MANAGERS.items():
        for extension_id in manager["ids"]:
            manifest = extension_manifest(profile, extension_id)
            settings = extension_settings(profile, extension_id)
            installed = bool(manifest or settings)
            if not installed:
                continue
            managers.append(
                {
                    "key": key,
                    "name": manager["name"],
                    "extensionId": extension_id,
                    "installed": installed,
                    "enabled": extension_enabled(settings),
                    "version": (manifest or settings.get("manifest") or {}).get("version"),
                    "scripts": user_script_metadata(profile, extension_id),
                }
            )
    return managers


def user_style_manager_status(profile):
    managers = []
    for key, manager in USER_STYLE_MANAGERS.items():
        for extension_id in manager["ids"]:
            manifest = extension_manifest(profile, extension_id)
            settings = extension_settings(profile, extension_id)
            installed = bool(manifest or settings)
            if not installed:
                continue
            managers.append(
                {
                    "key": key,
                    "name": manager["name"],
                    "extensionId": extension_id,
                    "installed": installed,
                    "enabled": extension_enabled(settings),
                    "version": (manifest or settings.get("manifest") or {}).get("version"),
                    "styles": user_script_metadata(profile, extension_id),
                }
            )
    return managers


def status(chrome, profile, number):
    matches = profile_processes(profile)
    user_script_managers = user_script_manager_status(profile)
    user_style_managers = user_style_manager_status(profile)
    user_script_manager_keys = {manager["key"] for manager in user_script_managers}
    user_style_manager_keys = {manager["key"] for manager in user_style_managers}
    return {
        "chrome": chrome,
        "profile": str(profile),
        "port": number,
        "browserUrl": devtools_url(HOST, number),
        "profileInUse": bool(matches),
        "profilePids": [pid for pid, _, _ in matches],
        "devtoolsAvailable": devtools_available(HOST, number),
        "portFree": port_free(HOST, number),
        "tampermonkeyInstalled": "tampermonkey" in user_script_manager_keys,
        "stylusInstalled": "stylus" in user_style_manager_keys,
        "userScriptManagers": user_script_managers,
        "userStyleManagers": user_style_managers,
        "loopbackNetworkPermissions": loopback_network_permissions(profile),
        "localViteUserscriptDiagnostics": local_vite_userscript_diagnostics(profile, number),
    }


def launch_browser(chrome, profile, number, url):
    profile.mkdir(parents=True, exist_ok=True)
    matches = profile_processes(profile)
    if matches:
        if devtools_available(HOST, number):
            return
        terminate_profile_processes(profile, number)
        matches = profile_processes(profile)
    if matches:
        lines = "\n".join(f"  pid {pid}: {command}" for pid, _, command in matches)
        raise RuntimeError(f"Chrome profile already in use: {profile}\n{lines}")
    ensure_loopback_network_default(profile)
    if not port_free(HOST, number):
        raise RuntimeError(f"Port {HOST}:{number} is already in use. Set OPENCODE_BROWSER_MCP_PORT to another free port.")
    launch_chrome(chrome, profile, number, url)
    try:
        wait_for_chrome(HOST, number)
    except RuntimeError:
        terminate_profile_processes(profile, number)
        raise


def launch_url(passthrough):
    if not passthrough or passthrough[0].startswith("-"):
        raise RuntimeError("--launch requires a URL, for example: browser-mcp --launch https://example.com")
    return passthrough[0]


def main():
    passthrough = sys.argv[1:]
    status_only = "--status" in passthrough or "--check" in passthrough
    launch_only = "--launch" in passthrough
    close_only = "--close" in passthrough
    passthrough = [arg for arg in passthrough if arg not in ("--server", "--status", "--check", "--launch", "--close")]

    profile = profile_dir()
    number = port()

    if close_only:
        terminate_profile_processes(profile, number)
        return 0

    if status_only or launch_only:
        chrome = chrome_path()

    if status_only:
        print(json.dumps(status(chrome, profile, number), indent=2))
        return 0

    if launch_only:
        launch_browser(chrome, profile, number, launch_url(passthrough))
        print(json.dumps(status(chrome, profile, number), indent=2))
        return 0

    return subprocess.call(mcp_command(number, passthrough), env=mcp_env())


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as exc:
        eprint(f"browser-mcp: {exc}")
        raise SystemExit(1)
