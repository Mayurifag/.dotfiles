#!/usr/bin/env python3
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path


DAY_SECONDS = 24 * 60 * 60
PIN_RE = re.compile(r'^(\s*opencode\s*=\s*")([^"]+)("\s*)$', re.MULTILINE)


def cache_file():
    if sys.platform == "win32":
        base = Path(os.environ.get("LOCALAPPDATA") or Path.home() / "AppData" / "Local")
    else:
        base = Path(os.environ.get("XDG_CACHE_HOME") or Path.home() / ".cache")
    return base / "opencode-launcher" / "last-check.json"


def source_dir():
    try:
        p = subprocess.run(["chezmoi", "source-path"], capture_output=True, text=True, timeout=10)
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return Path.home() / ".local" / "share" / "chezmoi"
    if p.returncode == 0 and p.stdout.strip():
        return Path(p.stdout.strip())
    return Path.home() / ".local" / "share" / "chezmoi"


def checked_recently(path):
    try:
        data = json.loads(path.read_text())
        checked_at = float(data.get("checked_at", 0))
    except (OSError, ValueError, TypeError):
        return False
    return time.time() - checked_at < DAY_SECONDS


def mark_checked(path):
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(json.dumps({"checked_at": time.time()}) + "\n")
    except OSError as e:
        print(f"c: failed to write update check state: {e}", file=sys.stderr)


def output(args, timeout=90):
    p = subprocess.run(args, capture_output=True, text=True, timeout=timeout)
    if p.returncode != 0:
        msg = (p.stderr or p.stdout).strip()
        raise RuntimeError(msg or f"{' '.join(args)} exited {p.returncode}")
    return p.stdout.strip()


def run(args):
    p = subprocess.run(args)
    if p.returncode != 0:
        raise RuntimeError(f"{' '.join(args)} exited {p.returncode}")


def current_pin(path):
    text = path.read_text()
    match = PIN_RE.search(text)
    if not match:
        raise RuntimeError(f"opencode pin not found in {path}")
    return text, match.group(2)


def update_pin(path, text, latest):
    updated = PIN_RE.sub(lambda m: f"{m.group(1)}{latest}{m.group(3)}", text, count=1)
    if updated != text:
        path.write_text(updated)


def maybe_update_opencode():
    state = cache_file()
    if checked_recently(state):
        return

    try:
        config = source_dir() / "dot_config" / "mise" / "config.toml.tmpl"
        text, pinned = current_pin(config)
        latest = output(["mise", "latest", "opencode"])
        if latest and latest != pinned:
            print(f"c: updating opencode {pinned} -> {latest}", file=sys.stderr)
            run(["mise", "install", f"opencode@{latest}"])
            update_pin(config, text, latest)
            run(["chezmoi", "apply"])
    except Exception as e:
        print(f"c: opencode update check failed: {e}", file=sys.stderr)
    finally:
        mark_checked(state)


def launch_opencode(argv):
    args = ["mise", "exec", "--", "opencode", *argv]
    if sys.platform == "win32":
        return subprocess.call(args)
    os.execvp("mise", args)
    return 127


def main(argv):
    maybe_update_opencode()
    return launch_opencode(argv)


raise SystemExit(main(sys.argv[1:]))
