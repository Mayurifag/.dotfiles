#!/usr/bin/env python3
import json
import os
import sys
import urllib.error
import urllib.request


def request_json(url, token, body):
    req = urllib.request.Request(
        url,
        data=json.dumps(body, separators=(",", ":")).encode(),
        headers={"17token": token, "Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=15) as resp:
        return json.loads(resp.read().decode())


number = sys.argv[1] if len(sys.argv) > 1 else None
if not number:
    print("Usage: ship <tracking_number>", file=sys.stderr)
    raise SystemExit(1)

token = os.environ.get("SEVENTEENTRACK_API_KEY")
if not token:
    print("ship: SEVENTEENTRACK_API_KEY not set", file=sys.stderr)
    raise SystemExit(1)

base = "https://api.17track.net/track/v2.2"
body = [{"number": number, "lang": "en"}]
try:
    resp = request_json(f"{base}/gettrackinfo", token, body)
except (urllib.error.URLError, TimeoutError, json.JSONDecodeError) as e:
    print(f"ship: {e}", file=sys.stderr)
    raise SystemExit(1)

if resp.get("code") != 0:
    print(f"ship: API code {resp.get('code')} - {json.dumps(resp, ensure_ascii=False)}", file=sys.stderr)
    raise SystemExit(1)

accepted = ((resp.get("data") or {}).get("accepted") or [])
track = accepted[0] if accepted else {}
info = track.get("track_info") or {}
if not info:
    try:
        request_json(f"{base}/register", token, body)
    except (urllib.error.URLError, TimeoutError, json.JSONDecodeError) as e:
        print(f"ship: register failed: {e}", file=sys.stderr)
        raise SystemExit(1)
    print(f"ship: registered {number} - retry in a moment for events")
    raise SystemExit(0)

status = info.get("latest_status") or {}
event = info.get("latest_event") or {}
print(f"Number:    {track.get('number', 'N/A')}")
print(f"Status:    {status.get('status', 'N/A')} / {status.get('sub_status', 'N/A')}")
print(f"Last:      {event.get('description', 'N/A')}")
print(f"Location:  {event.get('location', 'N/A')}")
print(f"Time:      {event.get('time_iso', 'N/A')}")
