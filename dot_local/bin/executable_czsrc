#!/usr/bin/env python3
import os
import shutil
import subprocess
import sys
from pathlib import Path


def output(*cmd):
    p = subprocess.run(cmd, capture_output=True, text=True)
    return p.stdout.strip() if p.returncode == 0 else ""


def resolve(path):
    src = output("chezmoi", "source-path", path)
    if not src:
        if subprocess.run(["chezmoi", "add", "--force", path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode != 0:
            print(f"czsrc: {path} not managed", file=sys.stderr)
            return None
        src = output("chezmoi", "source-path", path)
    if not src:
        print(f"czsrc: {path} not managed", file=sys.stderr)
        return None
    return src


def run_ai(tmpl, dest):
    model = os.environ.get("CZSRC_AI_MODEL", "opencode-go/minimax-m2.7")
    srcdir = output("chezmoi", "source-path") or str(Path.home() / ".local" / "share" / "chezmoi")
    rc = subprocess.run([
        "opencode",
        "run",
        "--model",
        model,
        "--dir",
        srcdir,
        f"Read the chezmoi template at {tmpl} and destination at {dest}. Run chezmoi diff {dest} to see what differs. Edit the template so its rendered output matches the destination exactly. Preserve ALL template logic: conditionals, includes, loops, OS checks. Do NOT edit the destination file.",
    ]).returncode
    if rc == 0:
        print(f"  updated {tmpl}")
        return 2
    print(f"  failed {tmpl} (exit {rc})")
    return 1


def sync(dest_path, label):
    src = resolve(dest_path)
    if not src:
        return 1
    dest = output("chezmoi", "target-path", src) or dest_path
    if src.endswith(".tmpl"):
        print(f"{label} -> {src} (AI)")
        return run_ai(src, dest_path)
    print(f"{label} -> {src}")
    try:
        shutil.copy2(dest, src)
    except OSError as e:
        print(f"  failed: {e}")
        return 1
    print("  copied")
    return 0

if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
    print("Usage: czsrc [path ...]")
    raise SystemExit(0)

if len(sys.argv) > 1:
    items = [(p, p) for p in sys.argv[1:]]
else:
    p = subprocess.run(["chezmoi", "status", "--include=changed", "--externals=false"], capture_output=True, text=True)
    if p.returncode != 0:
        sys.stderr.write(p.stderr)
        raise SystemExit(p.returncode)
    items = []
    for line in p.stdout.splitlines():
        dest = line[3:] if len(line) > 3 else ""
        if not dest:
            continue
        dest_path = str(Path.home() / dest)
        if output("chezmoi", "source-path", dest_path):
            items.append((dest_path, dest))
        elif output("chezmoi", "source-path", dest):
            items.append((dest, dest))
        else:
            items.append((dest_path, dest))

if not items:
    print("No changes - source and destination match.")
    raise SystemExit(0)

ok = tmpl = 0
failed = 0
for dest_path, label in items:
    rc = sync(dest_path, label)
    if rc == 0:
        ok += 1
    elif rc == 2:
        ok += 1
        tmpl += 1
    else:
        failed += 1

print()
print(f"Done: {ok} files synced ({tmpl} via AI)")
raise SystemExit(1 if failed else 0)
