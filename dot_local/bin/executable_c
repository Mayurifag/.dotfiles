#!/usr/bin/env python3
import json
import os
import subprocess
import sys
import time
from pathlib import Path


def output(*cmd):
    p = subprocess.run(cmd, capture_output=True, text=True)
    return p.stdout.strip() if p.returncode == 0 else ""


def project_key():
    root = output("git", "rev-parse", "--show-toplevel")
    return str(Path(root or os.getcwd()).resolve())


def state_path():
    if os.name == "nt":
        base = Path(os.environ.get("LOCALAPPDATA") or Path.home() / "AppData" / "Local") / "opencode"
    else:
        base = Path(os.environ.get("XDG_STATE_HOME") or Path.home() / ".local" / "state") / "opencode"
    base.mkdir(parents=True, exist_ok=True)
    return base / "c-sessions.json"


def load_state(path):
    try:
        return json.loads(path.read_text())
    except (OSError, json.JSONDecodeError):
        return {}


def save_state(path, state):
    tmp = path.with_suffix(".tmp")
    tmp.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n")
    tmp.replace(path)


def sessions():
    p = subprocess.run(["opencode", "session", "list", "--format", "json", "--max-count", "100"], capture_output=True, text=True)
    if p.returncode != 0:
        return []
    try:
        return json.loads(p.stdout)
    except json.JSONDecodeError:
        return []


def inside(directory, root):
    try:
        Path(directory).resolve().relative_to(root)
        return True
    except (OSError, ValueError):
        return False


key = project_key()
state_file = state_path()
state = load_state(state_file)
known = sessions()
tracked = state.get(key)
session_id = None

if not sys.argv[1:] and tracked:
    for session in known:
        if session.get("id") == tracked and inside(session.get("directory") or "", key):
            session_id = tracked
            break

started = int(time.time() * 1000)
cmd = ["opencode", "--session", session_id] if session_id else ["opencode", *sys.argv[1:]]
rc = subprocess.run(cmd).returncode

latest = None
for session in sessions():
    if inside(session.get("directory") or "", key) and session.get("updated", 0) >= started:
        if latest is None or session.get("updated", 0) > latest.get("updated", 0):
            latest = session

if latest and latest.get("id"):
    state[key] = latest["id"]
    save_state(state_file, state)
elif session_id:
    state[key] = session_id
    save_state(state_file, state)

raise SystemExit(rc)
