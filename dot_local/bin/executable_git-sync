#!/usr/bin/env bash
# git-sync: pull, prune, fast-forward all branches, then trim merged.
# Source: https://gist.github.com/foriequal0/55763d9177803c325904d089299f0970
# requires: (optional) git-trim

set -euo pipefail

git rev-parse --git-dir >/dev/null 2>&1 || exit 0

# Non-TTY (e.g. GitKraken hook) flags any stdout/stderr as a hook error popup.
# Redirect to a log file when not attached to a terminal.
if [[ ! -t 1 ]]; then
  mkdir -p "$HOME/.cache"
  exec >>"$HOME/.cache/git-sync.log" 2>&1
fi

auto=0
current=$(git branch --show-current)
dry_run=0
trim_bases=$(git config --get git-sync.trimBases 2>/dev/null || true)
trim_delete=$(git config --get git-sync.trimDelete 2>/dev/null || git config --get trim.delete 2>/dev/null || true)
trim_protected=$(git config --get git-sync.trimProtected 2>/dev/null || git config --get trim.protected 2>/dev/null || true)

while [[ $# -gt 0 ]]; do
  case "$1" in
    --auto) auto=1 ;;
    --dry-run) dry_run=1 ;;
  esac
  shift
done

config_dry_run=$(git config --type=bool --get git-sync.dryRun 2>/dev/null || true)
[[ "$config_dry_run" == "true" ]] && dry_run=1
[[ -n "$trim_delete" ]] || trim_delete="merged-local,local"
[[ -n "$trim_bases" || -z "$current" ]] || trim_bases="$current"

append_protected() {
  local branch="${1:-}"
  [[ -n "$branch" ]] || return 0

  if [[ -z "$trim_protected" ]]; then
    trim_protected="$branch"
  else
    trim_protected="$trim_protected,$branch"
  fi
}

remote_head_branches() {
  local branch ref

  while IFS= read -r ref; do
    [[ -n "$ref" ]] || continue
    branch="${ref#refs/remotes/}"
    branch="${branch#*/}"
    printf '%s\n' "$branch"
  done < <(git for-each-ref --format "%(symref)" refs/remotes)
}

is_remote_head_branch() {
  local branch="${1:-}" remote_head

  [[ -n "$branch" ]] || return 1
  while IFS= read -r remote_head; do
    [[ "$branch" == "$remote_head" ]] && return 0
  done < <(remote_head_branches)

  return 1
}

has_upstream() {
  local branch="${1:-}" upstream
  [[ -n "$branch" ]] || return 1

  upstream=$(git branch --list --format "%(upstream:short)" "$branch")
  [[ -n "$upstream" ]] || return 1
  git show-ref --quiet "$upstream"
}

has_merged_cleanup_target() {
  local branch="${1:-}" merged

  [[ -n "$branch" ]] || return 1
  while IFS= read -r merged; do
    [[ -n "$merged" ]] || continue
    [[ "$merged" != "$branch" ]] || continue
    is_remote_head_branch "$merged" && continue
    return 0
  done < <(git branch --merged "$branch" --format "%(refname:short)")

  return 1
}

is_cleanup_branch() {
  local branch="${1:-}"

  [[ -n "$branch" ]] || return 1
  is_remote_head_branch "$branch" && return 0
  has_upstream "$branch" || return 1
  has_merged_cleanup_target "$branch"
}

branch_checked_out() {
  local branch="${1:-}" line

  [[ -n "$branch" ]] || return 1
  while IFS= read -r line; do
    [[ "$line" == "branch refs/heads/${branch}" ]] && return 0
  done < <(git worktree list --porcelain)

  return 1
}

tracking_branches_with_upstream() {
  local branch upstream

  git branch --list --format "%(refname:short)%09%(upstream:short)" \
    | while IFS=$'\t' read -r branch upstream
  do
    [[ -n "$branch" && -n "$upstream" ]] || continue
    git show-ref --quiet "$upstream" || continue
    printf '%s\n' "$branch"
  done
}

is_protected() {
  local branch="${1:-}" pattern IFS=,

  for pattern in $trim_protected; do
    [[ -n "$pattern" ]] || continue
    # shellcheck disable=SC2053
    [[ "$branch" == $pattern ]] && return 0
  done

  return 1
}

prune_stale_remote_refs() {
  local ref remote short

  git for-each-ref --format "%(refname)" refs/remotes \
    | while IFS= read -r ref
  do
    short="${ref#refs/remotes/}"
    remote="${short%%/*}"

    [[ "$short" != "$remote" ]] || continue
    git remote get-url "$remote" >/dev/null 2>&1 && continue

    if [[ "$dry_run" == "1" ]]; then
      echo "Would delete stale remote ref '${ref}'"
    else
      echo "Deleting stale remote ref '${ref}'"
      git update-ref -d "$ref"
    fi
  done
}

fast_forward_tracking_branches() {
  local branch remote target_remote upstream

  git branch --list --format "%(refname:short)%09%(upstream:remotename)%09%(upstream:short)" \
    | while IFS=$'\t' read -r branch remote upstream
  do
    [[ -n "$upstream" ]] || continue
    [[ "$branch" != "$current" ]] || continue
    git show-ref --quiet "$upstream" || continue
    git merge-base --is-ancestor "$branch" "$upstream" || {
      echo "Not possible to fast-forward branch '${branch}' to '${upstream}'"
      continue
    }
    branch_checked_out "$branch" && {
      echo "Branch '${branch}' is checked out in another worktree, skipping."
      continue
    }

    for target_remote in $(git remote); do
      [[ "$remote" == "$target_remote" ]] || continue
      if [[ "$dry_run" == "1" ]]; then
        echo "Would fast-forward branch '${branch}' to '${upstream}'"
      else
        git branch --force "$branch" "$upstream"
      fi
    done
  done
}

fast_forward_current_branch() {
  local upstream

  [[ -n "$current" ]] || return 0
  upstream=$(git branch --list --format "%(upstream:short)" "$current")
  [[ -n "$upstream" ]] || return 0

  echo "Fast-forward branch '${current}' to '${upstream}'"
  if [[ "$dry_run" == "1" ]]; then
    echo "Would fast-forward branch '${current}' to '${upstream}'"
  else
    git merge --ff-only "$upstream" || true
  fi
}

trim_local_merged() {
  local branch

  [[ -n "$current" ]] || return 0
  git branch --merged "$current" --format "%(refname:short)" \
    | while IFS= read -r branch
  do
    [[ -n "$branch" ]] || continue
    [[ "$branch" != "$current" ]] || continue
    is_protected "$branch" && continue
    branch_checked_out "$branch" && {
      echo "Branch '${branch}' is checked out in another worktree, skipping."
      continue
    }

    if [[ "$dry_run" == "1" ]]; then
      echo "Would delete merged local branch '${branch}'"
    else
      git branch -d "$branch"
    fi
  done
}

run_git_trim() {
  local -a args

  command -v git-trim >/dev/null 2>&1 || return 0
  args=(--no-update --no-confirm --delete "$trim_delete")
  [[ -n "$trim_bases" ]] && args+=(--bases "$trim_bases")
  [[ -n "$trim_protected" ]] && args+=(--protected "$trim_protected")

  echo "git trim ${args[*]}"
  if [[ "$dry_run" == "1" ]]; then
    git trim --dry-run "${args[@]}"
  else
    git trim "${args[@]}"
  fi
}

if [[ "$auto" == "1" ]]; then
  [[ -n "$current" ]] || exit 0
  is_cleanup_branch "$current" || exit 0
fi

echo "git-sync $(date -u '+%Y-%m-%dT%H:%M:%SZ') $(pwd)"

if [[ "$dry_run" == "1" ]]; then
  echo "Would fetch --all --prune"
else
  git fetch --all --prune
fi

prune_stale_remote_refs

append_protected "$current"
while IFS= read -r branch; do
  append_protected "$branch"
done < <(remote_head_branches)
while IFS= read -r branch; do
  append_protected "$branch"
done < <(tracking_branches_with_upstream)

fast_forward_tracking_branches
fast_forward_current_branch
trim_local_merged
run_git_trim
