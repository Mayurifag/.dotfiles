#!/usr/bin/env python3
import re
import shutil
import subprocess
from pathlib import Path


def command_exists(name):
    return shutil.which(name) is not None


def output(*cmd):
    p = subprocess.run(cmd, capture_output=True, text=True)
    return p.stdout.strip() if p.returncode == 0 else ""


def git_ok(*args):
    return subprocess.run(["git", *args], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def ejson_is_decrypted(path):
    try:
        text = Path(path).read_text(encoding="utf-8", errors="replace")
    except OSError:
        return False
    for line in text.splitlines():
        if re.match(r'^\s*"[^_][^"]*"\s*:\s*"', line) and not re.search(r':\s*"EJ\[1:', line):
            return True
    return False


def git_crypt_repo():
    if Path(".git-crypt").exists():
        return True
    attrs = Path(".gitattributes")
    return attrs.exists() and "filter=git-crypt" in attrs.read_text(encoding="utf-8", errors="ignore")


def list_ejson():
    if git_ok("rev-parse", "--git-dir"):
        p = subprocess.run(["git", "ls-files", "--cached", "--others", "--exclude-standard", "*.ejson"], capture_output=True, text=True)
        return [Path(x) for x in p.stdout.splitlines() if x]
    return [p for p in Path.cwd().rglob("*.ejson") if ".git" not in p.parts]


did = False
if command_exists("ejson"):
    for path in list_ejson():
        if ejson_is_decrypted(path) and subprocess.run(["ejson", "encrypt", str(path)], stdout=subprocess.DEVNULL).returncode == 0:
            print(f"enc: encrypted {path}")
            did = True

if command_exists("git-crypt") and git_ok("rev-parse", "--git-dir") and git_crypt_repo() and output("git", "config", "--get", "filter.git-crypt.smudge"):
    if subprocess.run(["git-crypt", "lock"]).returncode == 0:
        print("enc: git-crypt locked")
        did = True

if not did:
    print("enc: nothing to encrypt")
