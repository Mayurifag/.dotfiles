#!/usr/bin/env python3
import subprocess
import sys
from urllib.parse import urlparse


DEFAULT_MODE = "live"
MODES = {
    "balanced": {
        "streamlink": [],
        "mpv": [
            "--demuxer-max-bytes=256MiB",
            "--demuxer-readahead-secs=60",
        ],
    },
    "live": {
        "streamlink": ["--twitch-low-latency", "--hls-live-edge", "2", "--hls-segment-stream-data"],
        "mpv": ["--profile=low-latency"],
    },
    "buffer": {
        "streamlink": ["--retry-streams", "5", "--retry-max", "20"],
        "mpv": [
            "--demuxer-max-bytes=512MiB",
            "--demuxer-readahead-secs=180",
        ],
    },
}
BASE_STREAMLINK_ARGS = ["--retry-open", "3"]
BASE_MPV_ARGS = [
    "--no-terminal",
    "--really-quiet",
    "--keep-open=no",
    "--loop-playlist=inf",
    "--loop-file=inf",
    "--no-resume-playback",
    "--force-window=immediate",
    "--cache=yes",
    "--demuxer-max-back-bytes=1800M",
    "--force-seekable=yes",
    "--hr-seek=yes",
    "--hr-seek-framedrop=yes",
]
USAGE = "Usage: s <url> [balanced|live|buffer]"


def popen_kwargs():
    kwargs = {
        "stdin": subprocess.DEVNULL,
        "stdout": subprocess.DEVNULL,
        "stderr": subprocess.DEVNULL,
    }
    if sys.platform == "win32":
        kwargs["creationflags"] = subprocess.DETACHED_PROCESS | subprocess.CREATE_NEW_PROCESS_GROUP
    else:
        kwargs["start_new_session"] = True
    return kwargs


def stream_url(value):
    if "://" in value:
        return value
    if "." in value:
        return f"https://{value}"
    return f"https://www.twitch.tv/{value}"


def title(value, url):
    parsed = urlparse(url)
    if parsed.netloc.lower().endswith("twitch.tv") and parsed.path.strip("/"):
        return f"Twitch:{parsed.path.strip('/').split('/')[0]}"
    if "://" not in value and "." not in value:
        return f"Twitch:{value}"
    return "Streamlink"


def main(argv):
    if not argv:
        print(USAGE, file=sys.stderr)
        return 1
    if argv[0] in ("-h", "--help"):
        print(USAGE)
        return 0
    if len(argv) > 2:
        print(USAGE, file=sys.stderr)
        return 1

    url = stream_url(argv[0])
    mode = argv[1] if len(argv) == 2 else DEFAULT_MODE
    options = MODES.get(mode)
    if options is None:
        print(USAGE, file=sys.stderr)
        return 1

    mpv_args = BASE_MPV_ARGS + [f"--title={title(argv[0], url)}"] + options["mpv"] + ["{filename}"]
    args = [
        "streamlink",
        *BASE_STREAMLINK_ARGS,
        "--player",
        "mpv",
        *options["streamlink"],
        "--player-args",
        " ".join(mpv_args),
        url,
        "best",
    ]
    try:
        subprocess.Popen(args, **popen_kwargs())
    except FileNotFoundError:
        print("s: streamlink not found", file=sys.stderr)
        return 1
    return 0


raise SystemExit(main(sys.argv[1:]))
