{{- /* env_vars_posix — POSIX export statements for bash/zsh */}}
{{- /* Include with: {{ template "env_vars_posix" . }} (trailing dot is mandatory) */}}
export EDITOR={{ .sharedEnv.EDITOR }}
export VISUAL={{ .sharedEnv.VISUAL }}
export LC_ALL={{ .sharedEnv.LC_ALL }}
export SUDO_EDITOR={{ .sharedEnv.SUDO_EDITOR }}
export GEMINI_API_KEY="{{ (joinPath .chezmoi.sourceDir "keys.ejson" | ejsonDecrypt).gemini_api_key }}"
export CONTEXT7_API_KEY="{{ (joinPath .chezmoi.sourceDir "keys.ejson" | ejsonDecrypt).context7_api_key }}"
export SEVENTEENTRACK_API_KEY="{{ (joinPath .chezmoi.sourceDir "keys.ejson" | ejsonDecrypt).seventeentrack_api_key }}"
export FZF_DEFAULT_COMMAND='rg --files --hidden'
export FZF_DEFAULT_OPTS='-m --height 50% --border=rounded'
export DO_NOT_TRACK=1
export HOMEBREW_NO_ANALYTICS=1
export NEXT_TELEMETRY_DISABLED=1
export VSCODE_TELEMETRY_LEVEL=off
export POWERSHELL_TELEMETRY_OPTOUT=1
export GOTELEMETRY=off
export OMO_SEND_ANONYMOUS_TELEMETRY=0
export OMO_DISABLE_POSTHOG=1
export PROXIES_CFG="$HOME/Code/proxies-cfg"
