function gp {
    $branch = git symbolic-ref --short HEAD
    if (git config "branch.$branch.merge") { git push @args } else { git push -u origin $branch @args }
}
function reset_file {
    $branch = $null
    if (git rev-parse --verify --quiet origin/main 2>$null) { $branch = "main" }
    elseif (git rev-parse --verify --quiet origin/master 2>$null) { $branch = "master" }
    else { Write-Error "reset_file: cannot determine default branch"; return }
    git checkout "origin/$branch" -- @args
}
function gcd {
    git clone --recurse-submodules $args[0]
    if ($LASTEXITCODE -eq 0) {
        $dir = [System.IO.Path]::GetFileNameWithoutExtension($args[0].Split('/')[-1])
        Set-Location $dir
    }
}
function grom {
    $branch = $null
    if (git rev-parse --verify --quiet origin/main 2>$null) { $branch = "main" }
    elseif (git rev-parse --verify --quiet origin/master 2>$null) { $branch = "master" }
    elseif (git rev-parse --verify --quiet origin/dev 2>$null) { $branch = "dev" }
    elseif (git rev-parse --verify --quiet origin/source 2>$null) { $branch = "source" }
    else { Write-Error "grom: neither 'origin/main', 'origin/master' nor 'origin/dev' branch exists"; return }
    $env:LEFTHOOK = "0"
    git rebase -i "origin/$branch"
    Remove-Item Env:\LEFTHOOK -ErrorAction SilentlyContinue
    git submodule update --init --recursive
}
function prg {
    git pull -a | Out-Null
    $branches = git branch --list '*[^master][^main]' --format='%(refname:short)' | Where-Object { $_ -ne '' }
    if (-not $branches) { Write-Host "No branches to delete."; return }
    Write-Host ($branches -join "`n")
    $ans = Read-Host "Do you want to delete these merged branches? (y/n)"
    if ($ans -notmatch '^[yY]$') { return }
    git remote prune origin
    $branches | ForEach-Object { git branch -D $_ }
}

## npm (complex)
function npmug {
    $before = npm list -g --depth=0 --json 2>$null | ConvertFrom-Json
    npm update -g @args
    $after = npm list -g --depth=0 --json 2>$null | ConvertFrom-Json
    $bDeps = if ($before.dependencies) { $before.dependencies } else { @{} }
    $aDeps = if ($after.dependencies) { $after.dependencies } else { @{} }
    $changed = $aDeps.PSObject.Properties | Where-Object { $bDeps.($_.Name)?.version -ne $_.Value.version }
    if (-not $changed) { Write-Host "Nothing updated."; return }
    $changed | ForEach-Object {
        $from = if ($bDeps.($_.Name)) { $bDeps.($_.Name).version } else { '(new)' }
        Write-Host "$($_.Name): $from → $($_.Value.version)"
    }
}

## System utilities (complex)
function myip {
    $ip = $null
    try { $ip = (Resolve-DnsName -Name myip.opendns.com -Server resolver1.opendns.com -Type A -ErrorAction Stop).IPAddress } catch {}
    if (-not $ip) { try { $ip = (Invoke-WebRequest -Uri 'http://ipecho.net/plain' -UseBasicParsing -TimeoutSec 3).Content.Trim() } catch {} }
    if ($ip) { Write-Output $ip } else { Write-Warning "myip: could not determine public IP" }
}
function free {
    $os = Get-CimInstance Win32_OperatingSystem
    $total = [int]($os.TotalVisibleMemorySize / 1024)
    $free  = [int]($os.FreePhysicalMemory / 1024)
    $used  = $total - $free
    Write-Output "              total        used        free"
    Write-Output ("Mem:   {0,11}  {1,10}  {2,10}" -f $total, $used, $free)
}

## GitKraken
function gk {
    $gkExe = Get-Item "$env:LOCALAPPDATA\gitkraken\app-*\gitkraken.exe" -ErrorAction SilentlyContinue | Sort-Object Name -Descending | Select-Object -First 1 -ExpandProperty FullName
    if (-not $gkExe) { Write-Warning "GitKraken not found"; return }
    $root = git rev-parse --show-toplevel 2>$null
    if (-not $root) { Write-Warning "Not a git repository"; return }
    $root = (Resolve-Path $root).Path
    Start-Process -FilePath $gkExe -ArgumentList "--new-window", "-p", $root -RedirectStandardError NUL
}
Set-Alias -Name g -Value gk

## Claude Code
function a { claude -p --strict-mcp-config --tools "" --no-session-persistence --disable-slash-commands --model claude-haiku-4-5-20251001 --append-system-prompt "Be concise." --output-format text ($args -join ' ') | glow - }
function claude-clean {
    $dirs = @('shell-snapshots', 'file-history', 'paste-cache', 'backups', 'cache', 'debug')
    $total = 0
    foreach ($d in $dirs) {
        $target = Join-Path $env:USERPROFILE ".claude\$d"
        if (Test-Path $target) {
            $items = Get-ChildItem -Path $target -Recurse -File -ErrorAction SilentlyContinue
            $count = ($items | Measure-Object).Count
            $size = ($items | Measure-Object -Property Length -Sum).Sum
            $sizeMB = [math]::Round($size / 1MB, 1)
            $total += $count
            Write-Host "Cleaning $d (${sizeMB}MB)"
            Remove-Item "$target\*" -Recurse -Force -ErrorAction SilentlyContinue
        }
    }
    Write-Host "Removed $total file(s)"
}

## Shell utilities (complex)
function mkcd {
    New-Item -ItemType Directory -Path $args[0] -Force | Out-Null
    Set-Location $args[0]
}

## Apps (complex)
function f { if ($args.Count -eq 0) { code . } else { code @args } }
function webmtogif {
    param([Parameter(Mandatory)][string]$in)
    if ([IO.Path]::GetExtension($in) -ieq '.gif') {
        Write-Error "webmtogif: input already .gif"; return
    }
    $out = [IO.Path]::ChangeExtension($in, 'gif')
    ffmpeg -i $in -vf "fps=15,scale=480:-1:flags=lanczos" -loop 0 $out
}
function c {
    $env:IS_SANDBOX = "1"
    claude --dangerously-skip-permissions @args
    Remove-Item Env:\IS_SANDBOX -ErrorAction SilentlyContinue
}
function q {
    if (Get-Command yawn-debug -ErrorAction SilentlyContinue) {
        Write-Host "Executing yawn-debug"
        yawn-debug @args
    } elseif (Get-Command yawn -ErrorAction SilentlyContinue) {
        yawn @args
    } else {
        Write-Error "No yawn executable found."
    }
}

## Xray (complex)
function xray-add($d, $p = 'proxy_it') { make -C $env:XRAY_CFG add-domain domain=$d proxy=$p }
function xray-rm($d) { make -C $env:XRAY_CFG remove-domain domain=$d }
function xray-remove($d) { xray-rm $d }
