## Crypto: smart enc/dec for ejson + git-crypt
function _EjsonIsDecrypted {
    param([string]$Path)
    $lines = Select-String -Path $Path -Pattern '^\s*"[^_][^"]*"\s*:\s*"' -ErrorAction SilentlyContinue
    if (-not $lines) { return $false }
    foreach ($l in $lines) {
        if ($l.Line -notmatch ':\s*"EJ\[1:') { return $true }
    }
    return $false
}
function _GitCryptUnlocked { [bool](git config --get filter.git-crypt.smudge 2>$null) }
function _GitCryptRepo {
    if (Test-Path .git-crypt) { return $true }
    if ((Test-Path .gitattributes) -and (Select-String -Path .gitattributes -Pattern 'filter=git-crypt' -Quiet)) { return $true }
    return $false
}
function _ListEjson {
    if (git rev-parse --git-dir 2>$null) {
        git ls-files --cached --others --exclude-standard '*.ejson' | Where-Object { $_ }
    } else {
        Get-ChildItem -Path . -Recurse -Filter *.ejson -File -ErrorAction SilentlyContinue |
            Where-Object { $_.FullName -notmatch '[\\/]\.git[\\/]' } | ForEach-Object { $_.FullName }
    }
}
function enc {
    $did = $false
    if (Get-Command ejson -ErrorAction SilentlyContinue) {
        _ListEjson | ForEach-Object {
            if (_EjsonIsDecrypted $_) {
                ejson encrypt $_ | Out-Null
                if ($LASTEXITCODE -eq 0) { Write-Host "enc: encrypted $_"; $did = $true }
            }
        }
    }
    if ((Get-Command git-crypt -ErrorAction SilentlyContinue) -and (git rev-parse --git-dir 2>$null) -and (_GitCryptRepo) -and (_GitCryptUnlocked)) {
        git-crypt lock
        if ($LASTEXITCODE -eq 0) { Write-Host "enc: git-crypt locked"; $did = $true }
    }
    if (-not $did) { Write-Host "enc: nothing to encrypt" }
}
function dec {
    $did = $false
    if (Get-Command ejson -ErrorAction SilentlyContinue) {
        _ListEjson | ForEach-Object {
            $f = $_
            if (-not (_EjsonIsDecrypted $f)) {
                $tmp = New-TemporaryFile
                ejson decrypt $f 2>$null | Out-File -FilePath $tmp -Encoding utf8 -NoNewline
                if ($LASTEXITCODE -eq 0 -and (Get-Item $tmp).Length -gt 0) {
                    Move-Item -Path $tmp -Destination $f -Force
                    Write-Host "dec: decrypted $f"; $did = $true
                } else {
                    Remove-Item $tmp -ErrorAction SilentlyContinue
                    Write-Error "dec: failed $f"
                }
            }
        }
    }
    if ((Get-Command git-crypt -ErrorAction SilentlyContinue) -and (git rev-parse --git-dir 2>$null) -and (_GitCryptRepo) -and (-not (_GitCryptUnlocked))) {
        git-crypt unlock
        if ($LASTEXITCODE -eq 0) { Write-Host "dec: git-crypt unlocked"; $did = $true }
    }
    if (-not $did) { Write-Host "dec: nothing to decrypt" }
}

function _czsrc_ai {
    param($tmpl, $dest)

    $model = if ($env:CZSRC_AI_MODEL) { $env:CZSRC_AI_MODEL } else { 'opencode-go/deepseek-v4-flash' }
    $srcdir = chezmoi source-path 2>$null
    if (-not $srcdir) { $srcdir = "$HOME/.local/share/chezmoi" }

    opencode run --dangerously-skip-permissions --model $model --dir $srcdir `
        "Read the chezmoi template at $tmpl and destination at $dest. Run chezmoi diff $dest to see what differs. Edit the template so its rendered output matches the destination exactly. Preserve ALL template logic: conditionals, includes, loops, OS checks. Do NOT edit the destination file."

    if ($LASTEXITCODE -eq 0) {
        Write-Host "  updated $tmpl"
        return $true
    } else {
        Write-Host "  failed $tmpl (exit $LASTEXITCODE)"
        return $false
    }
}

function _czsrc_resolve {
    param($path)
    $s = chezmoi source-path $path 2>$null
    if (-not $s) {
        chezmoi add --force $path 2>$null | Out-Null
        if ($LASTEXITCODE -ne 0) { Write-Warning "czsrc: $path not managed"; return $null }
        $s = chezmoi source-path $path 2>$null
        if (-not $s) { Write-Warning "czsrc: $path not managed"; return $null }
    }
    return $s
}

function czsrc {
    if ($Args -and ($Args[0] -eq '-h' -or $Args[0] -eq '--help')) {
        Write-Host "Usage: czsrc [path ...]"
        Write-Host ""
        Write-Host "  Auto-sync destination changes back to chezmoi sources."
        Write-Host "  Plain files: copied directly. Templates: reverse-engineered via opencode."
        Write-Host ""
        Write-Host "  czsrc             Process all changed files (chezmoi diff)."
        Write-Host "  czsrc ~/.zshrc    Process specific file(s) only."
        Write-Host ""
        Write-Host "  Uses opencode-go/deepseek-v4-flash by default."
        Write-Host "  Set CZSRC_AI_MODEL to override (format: provider/model)."
        return
    }

    $changed = 0
    $tmplCount = 0
    $okCount = 0

    if ($Args.Count -gt 0) {
        foreach ($destPath in $Args) {
            $changed = 1
            $src = _czsrc_resolve $destPath
            if (-not $src) { continue }
            $dest = chezmoi target-path $src 2>$null
            if (-not $dest) { $dest = $destPath }

            if ($src -like '*.tmpl') {
                $tmplCount++
                Write-Host "$dest -> $src (AI)"
                if (_czsrc_ai $src $destPath) { $okCount++ }
            } else {
                Write-Host "$dest -> $src"
                try {
                    Copy-Item -Path $destPath -Destination $src -Force -ErrorAction Stop
                    Write-Host "  copied"
                    $okCount++
                } catch {
                    Write-Host "  failed : $_"
                }
            }
        }
    } else {
        $diffOutput = chezmoi diff 2>$null
        if (-not $diffOutput) {
            Write-Host "No changes - source and destination match."
            return
        }

        $dests = $diffOutput |
            Select-String '^diff --git' |
            ForEach-Object { $_.Line -replace '^diff --git a/', '' -replace ' b/.*', '' }

        foreach ($dest in $dests) {
            if (-not $dest) { continue }
            $changed = 1
            $destPath = if ($dest.StartsWith('/')) { $dest } else { "$HOME/$dest" }
            $src = _czsrc_resolve $destPath
            if (-not $src) { continue }

            if ($src -like '*.tmpl') {
                $tmplCount++
                Write-Host "$dest -> $src (AI)"
                if (_czsrc_ai $src $destPath) { $okCount++ }
            } else {
                Write-Host "$dest -> $src"
                try {
                    Copy-Item -Path $destPath -Destination $src -Force -ErrorAction Stop
                    Write-Host "  copied"
                    $okCount++
                } catch {
                    Write-Host "  failed : $_"
                }
            }
        }
    }

    if ($changed -eq 0) {
        Write-Host "No changes - source and destination match."
        return
    }

    Write-Host ""
    Write-Host "Done: $okCount files synced ($tmplCount via AI)"
}
