## Claude Code
a() { claude -p --bare --model claude-haiku-4-5-20251001 --append-system-prompt "Be concise." --output-format text "$*"; }
claude-clean() {
  local dirs=(shell-snapshots file-history paste-cache backups cache debug)
  local total=0
  for d in "${dirs[@]}"; do
    local target="$HOME/.claude/$d"
    if [ -d "$target" ]; then
      local size
      size=$(du -sh "$target" 2>/dev/null | cut -f1)
      total=$((total + $(find "$target" -type f 2>/dev/null | wc -l)))
      echo "Cleaning $d ($size)"
      rm -rf "${target:?}/"*
    fi
  done
  echo "Removed $total file(s)"
}

