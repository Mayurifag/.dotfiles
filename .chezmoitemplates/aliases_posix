alias ....='builtin cd ....'

{{- /* Generated simple aliases — mapped by category */}}
{{- $groups := keys .sharedAliases | sortAlpha }}
{{- range $groupName := $groups }}

## {{ $groupName }}
{{- $groupData := index $.sharedAliases $groupName }}
{{- $aliasNames := keys $groupData | sortAlpha }}
{{- range $aliasName := $aliasNames }}
{{- $data := index $groupData $aliasName }}
