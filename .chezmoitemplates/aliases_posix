## Git (complex)
sq() {
  local base
  if git rev-parse --abbrev-ref "@{upstream}" >/dev/null 2>&1; then
    base=$(git merge-base HEAD "@{upstream}")
  elif git rev-parse origin/main >/dev/null 2>&1; then
    base=$(git merge-base HEAD origin/main)
  elif git rev-parse origin/master >/dev/null 2>&1; then
    base=$(git merge-base HEAD origin/master)
  else
    echo "sq: cannot determine branch base" >&2; return 1
  fi
  local count first_sha first_msg
  count=$(git rev-list --count "${base}..HEAD")
  if[ "$count" -le 1 ]; then
    echo "sq: only ${count} commit(s) — nothing to squash"; return 0
  fi
  first_sha=$(git log --format='%H' "${base}..HEAD" | tail -1)
  first_msg=$(git log --format='%B' -1 "$first_sha")
  git reset --soft "$base"
  git commit -m "$first_msg"
  printf 'Force push? [y/N] '
  read -r _sq_ans
  case "$_sq_ans" in
    [yY]) git push origin HEAD --force-with-lease ;;
    *) echo "Skipped force push" ;;
  esac
}

