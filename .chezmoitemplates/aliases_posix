## Claude Code
a() { claude -p --strict-mcp-config --tools "" --no-session-persistence --disable-slash-commands --model claude-haiku-4-5-20251001 --append-system-prompt "Be concise." --output-format text "$*" | glow -; }
claude-clean() {
  local dirs=(shell-snapshots file-history paste-cache backups cache debug)
  local total=0
  for d in "${dirs[@]}"; do
    local target="$HOME/.claude/$d"
    if [ -d "$target" ]; then
      local size
      size=$(du -sh "$target" 2>/dev/null | cut -f1)
      total=$((total + $(find "$target" -type f 2>/dev/null | wc -l)))
      echo "Cleaning $d ($size)"
      rm -rf "${target:?}/"*
    fi
  done
  echo "Removed $total file(s)"
}

## npm (complex)
npmug() {
  local before after
  before=$(npm list -g --depth=0 --json 2>/dev/null)
  npm update -g "$@"
  after=$(npm list -g --depth=0 --json 2>/dev/null)
  node -e "
    const b = JSON.parse(process.argv[1]).dependencies || {};
    const a = JSON.parse(process.argv[2]).dependencies || {};
    const changed = Object.keys(a).filter(k => b[k]?.version !== a[k]?.version);
    if (!changed.length) { console.log('Nothing updated.'); process.exit(0); }
    changed.forEach(k => {
      const from = b[k] ? b[k].version : '(new)';
      console.log(k + ': ' + from + ' \u2192 ' + a[k].version);
    });
  " "$before" "$after"
}

