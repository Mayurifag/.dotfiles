gp() {
  local branch
  branch=$(git symbolic-ref --short HEAD)
  if [ -z "$(git config "branch.${branch}.merge")" ]; then
    git push -u origin "$branch" "$@"
  else
    git push "$@"
  fi
}
reset_file() {
  local branch
  if git rev-parse --verify --quiet origin/main > /dev/null 2>&1; then
    branch=main
  elif git rev-parse --verify --quiet origin/master > /dev/null 2>&1; then
    branch=master
  else
    echo "reset_file: cannot determine default branch" >&2; return 1
  fi
  git checkout "origin/$branch" -- "$@"
}

## Apps (complex)
f() { if [ $# -eq 0 ]; then code .; else code "$@"; fi }
webmtogif() {
  case "$1" in
    *.gif|*.GIF) echo "webmtogif: input already .gif" >&2; return 1 ;;
  esac
  ffmpeg -i "$1" -vf "fps=15,scale=480:-1:flags=lanczos" -loop 0 "${1%.*}.gif"
}

## npm (complex)
npmug() {
  local before after
  before=$(npm list -g --depth=0 --json 2>/dev/null)
  npm update -g "$@"
  after=$(npm list -g --depth=0 --json 2>/dev/null)
  node -e "
    const b = JSON.parse(process.argv[1]).dependencies || {};
    const a = JSON.parse(process.argv[2]).dependencies || {};
    const changed = Object.keys(a).filter(k => b[k]?.version !== a[k]?.version);
    if (!changed.length) { console.log('Nothing updated.'); process.exit(0); }
    changed.forEach(k => {
      const from = b[k] ? b[k].version : '(new)';
      console.log(k + ': ' + from + ' \u2192 ' + a[k].version);
    });
  " "$before" "$after"
}

