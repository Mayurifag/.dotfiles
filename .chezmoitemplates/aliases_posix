## Crypto: smart enc/dec for ejson + git-crypt
_ejson_is_decrypted() {
  grep -E '^[[:space:]]*"[^_][^"]*"[[:space:]]*:[[:space:]]*"' "$1" 2>/dev/null | grep -qvE ':[[:space:]]*"EJ\[1:'
}
_git_crypt_unlocked() {
  git config --get filter.git-crypt.smudge >/dev/null 2>&1
}
_git_crypt_repo() {
  [ -d .git-crypt ] || { [ -f .gitattributes ] && grep -q 'filter=git-crypt' .gitattributes; }
}
_list_ejson() {
  if git rev-parse --git-dir >/dev/null 2>&1; then
    git ls-files --cached --others --exclude-standard '*.ejson'
  else
    find . -type f -name '*.ejson' -not -path '*/.git/*' 2>/dev/null
  fi
}
enc() {
  local did=0 f
  if command -v ejson >/dev/null 2>&1; then
    while IFS= read -r f; do
      [ -z "$f" ] && continue
      if _ejson_is_decrypted "$f"; then
        ejson encrypt "$f" >/dev/null && { echo "enc: encrypted $f"; did=1; }
      fi
    done <<EOF
$(_list_ejson)
EOF
  fi
  if command -v git-crypt >/dev/null 2>&1 && git rev-parse --git-dir >/dev/null 2>&1 && _git_crypt_repo && _git_crypt_unlocked; then
    git-crypt lock && { echo "enc: git-crypt locked"; did=1; }
  fi
  [ "$did" = "0" ] && echo "enc: nothing to encrypt"
}
dec() {
  local did=0 f tmp
  if command -v ejson >/dev/null 2>&1; then
    while IFS= read -r f; do
      [ -z "$f" ] && continue
      if ! _ejson_is_decrypted "$f"; then
        tmp=$(mktemp) || continue
        if ejson decrypt "$f" >"$tmp" 2>/dev/null; then
          mv "$tmp" "$f" && { echo "dec: decrypted $f"; did=1; }
        else
          rm -f "$tmp"
          echo "dec: failed $f" >&2
        fi
      fi
    done <<EOF
$(_list_ejson)
EOF
  fi
  if command -v git-crypt >/dev/null 2>&1 && git rev-parse --git-dir >/dev/null 2>&1 && _git_crypt_repo && ! _git_crypt_unlocked; then
    git-crypt unlock && { echo "dec: git-crypt unlocked"; did=1; }
  fi
  [ "$did" = "0" ] && echo "dec: nothing to decrypt"
}

_czsrc_ai() {
  local tmpl="$1" dest="$2"
  local model="${CZSRC_AI_MODEL:-opencode-go/deepseek-v4-flash}"
  local srcdir
  srcdir=$(chezmoi source-path 2>/dev/null) || srcdir="$HOME/.local/share/chezmoi"

  opencode run --dangerously-skip-permissions --model "$model" --dir "$srcdir" \
    "Read the chezmoi template at $tmpl and destination at $dest. Run chezmoi diff $dest to see what differs. Edit the template so its rendered output matches the destination exactly. Preserve ALL template logic: conditionals, includes, loops, OS checks. Do NOT edit the destination file."

  local rc=$?
  if [ "$rc" = "0" ]; then
    echo " ✓ updated $tmpl"
  else
    echo " ✗ failed $tmpl (exit $rc)"
  fi
  return $rc
}

czsrc() {
  [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] && {
    echo "Usage: czsrc [path ...]"
    echo ""
    echo "  Auto-sync destination changes back to chezmoi sources."
    echo "  Plain files: copied directly. Templates: reverse-engineered via opencode."
    echo ""
    echo "  czsrc             Process all changed files (chezmoi diff)."
    echo "  czsrc ~/.zshrc    Process specific file(s) only."
    echo ""
    echo "  Uses opencode-go/deepseek-v4-flash by default."
    echo "  Set CZSRC_AI_MODEL to override (format: provider/model)."
    return 0
  }

  local dest src dest_path changed=0 tmpl_count=0 ok_count=0

  _czsrc_resolve() {
    local p="$1"
    src=$(chezmoi source-path "$p" 2>/dev/null)
    if [ -z "$src" ]; then
      chezmoi add --force "$p" 2>/dev/null || { echo "czsrc: $p not managed" >&2; return 1; }
      src=$(chezmoi source-path "$p" 2>/dev/null)
      [ -z "$src" ] && { echo "czsrc: $p not managed" >&2; return 1; }
    fi
    return 0
  }

  if [ $# -gt 0 ]; then
    for dest_path in "$@"; do
      changed=1
      _czsrc_resolve "$dest_path" || continue
      dest=$(chezmoi target-path "$src" 2>/dev/null)
      [ -z "$dest" ] && dest="$dest_path"

      if [[ "$src" == *.tmpl ]]; then
        tmpl_count=$((tmpl_count + 1))
        echo "$dest → $src (AI)"
        _czsrc_ai "$src" "$dest_path" && ok_count=$((ok_count + 1))
      else
        echo "$dest → $src"
        cp "$dest_path" "$src" && { echo "  ✓ copied"; ok_count=$((ok_count + 1)); } || echo "  ✗ failed"
      fi
    done
  else
    while IFS= read -r dest; do
      [ -z "$dest" ] && continue
      changed=1
      dest_path="$HOME/$dest"
      _czsrc_resolve "$dest_path" || continue

      if [[ "$src" == *.tmpl ]]; then
        tmpl_count=$((tmpl_count + 1))
        echo "$dest → $src (AI)"
        _czsrc_ai "$src" "$dest_path" && ok_count=$((ok_count + 1))
      else
        echo "$dest → $src"
        cp "$dest_path" "$src" && { echo "  ✓ copied"; ok_count=$((ok_count + 1)); } || echo "  ✗ failed"
      fi
    done < <(chezmoi diff 2>/dev/null | grep '^diff --git' | sed 's|^diff --git a/||;s| b/.*||')
  fi

  [ "$changed" = "0" ] && { echo "No changes — source and destination match."; return 0; }

  echo ""
  echo "Done: $ok_count files synced (${tmpl_count} via AI)"
}
